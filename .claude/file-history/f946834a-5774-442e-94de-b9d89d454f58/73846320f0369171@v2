from __future__ import annotations

import os
import sqlite3
import threading
import time
from contextlib import contextmanager
from typing import Any, Generator, Optional

DB_PATH = os.environ.get("EL_DB_PATH", ".el_data.db")

_PRAGMAS = (
    "PRAGMA journal_mode=WAL",
    "PRAGMA synchronous=NORMAL",
    "PRAGMA busy_timeout=5000",
    "PRAGMA foreign_keys=ON",
    "PRAGMA cache_size=-8000",        # 8 MB
    "PRAGMA mmap_size=67108864",      # 64 MB
    "PRAGMA temp_store=MEMORY",
)

MAX_RETRIES = 3
RETRY_DELAY = 0.05

_local = threading.local()


def _apply_pragmas(conn: sqlite3.Connection) -> None:
    for pragma in _PRAGMAS:
        try:
            conn.execute(pragma)
        except sqlite3.OperationalError:
            pass


def get_connection(db_path: Optional[str] = None) -> sqlite3.Connection:
    """Return a thread-local connection with WAL and production pragmas applied."""
    path = db_path or DB_PATH
    conn = getattr(_local, "conn", None)
    if conn is None:
        conn = sqlite3.connect(path, check_same_thread=False)
        conn.row_factory = sqlite3.Row
        _apply_pragmas(conn)
        _local.conn = conn
    return conn


@contextmanager
def transaction(db_path: Optional[str] = None, *, readonly: bool = False) -> Generator[sqlite3.Connection, None, None]:
    """Context manager for database connections with retry logic."""
    path = db_path or DB_PATH
    last_err: Optional[sqlite3.OperationalError] = None

    for attempt in range(MAX_RETRIES):
        conn = None
        try:
            conn = sqlite3.connect(path)
            conn.row_factory = sqlite3.Row
            _apply_pragmas(conn)

            if readonly:
                conn.execute("PRAGMA query_only=ON")

            yield conn

            if not readonly:
                conn.commit()
            return

        except sqlite3.OperationalError as e:
            last_err = e
            if "locked" not in str(e).lower() and "busy" not in str(e).lower():
                raise
            if attempt < MAX_RETRIES - 1:
                time.sleep(RETRY_DELAY * (2**attempt))
        except Exception:
            if conn and not readonly:
                try:
                    conn.rollback()
                except Exception:
                    pass
            raise
        finally:
            if conn:
                try:
                    conn.close()
                except Exception:
                    pass

    raise last_err  # type: ignore[misc]


def get_db_path() -> str:
    return DB_PATH


def get_library_size(db_path: Optional[str] = None) -> int:
    path = db_path or DB_PATH
    try:
        with transaction(path, readonly=True) as conn:
            row = conn.execute("SELECT COUNT(*) as cnt FROM equation_library").fetchone()
            return int(row["cnt"]) if row else 0
    except Exception:
        return 0
