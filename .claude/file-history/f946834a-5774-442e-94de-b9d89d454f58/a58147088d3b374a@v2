from __future__ import annotations

import hashlib
import hmac
import os
import secrets
from typing import Dict, Optional

from fastapi import Header, HTTPException, Request

_API_KEYS: Dict[str, str] = {}


def _load_keys() -> Dict[str, str]:
    """Load API keys from env. Format: EL_API_KEYS=key1:name1,key2:name2."""
    raw = os.environ.get("EL_API_KEYS", "")
    if not raw:
        return {}
    result: Dict[str, str] = {}
    for pair in raw.split(","):
        pair = pair.strip()
        if not pair:
            continue
        parts = pair.split(":", 1)
        if len(parts) == 2:
            result[parts[0]] = parts[1]
        else:
            result[parts[0]] = "unnamed"
    return result


def generate_api_key(name: str = "default") -> str:
    """Generate a cryptographically random API key. Store it in EL_API_KEYS env."""
    raw = secrets.token_urlsafe(32)
    return f"el_{raw}"


def _timing_safe_compare(a: str, b: str) -> bool:
    return hmac.compare_digest(a.encode(), b.encode())


async def authenticate(request: Request, x_api_key: Optional[str] = Header(None, alias="X-API-Key")) -> None:
    """FastAPI dependency — reject unauthenticated requests on /v1/* paths."""
    if not request.url.path.startswith("/v1/"):
        return

    if request.url.path == "/v1/health":
        return

    keys = _load_keys()
    if not keys:
        return

    if not x_api_key:
        raise HTTPException(401, "Missing X-API-Key header")

    if x_api_key not in keys:
        raise HTTPException(403, "Invalid API key")

    request.state.api_client = keys[x_api_key]
