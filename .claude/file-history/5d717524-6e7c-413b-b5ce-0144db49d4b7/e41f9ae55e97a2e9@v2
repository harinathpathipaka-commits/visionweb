[project]
name = "ans-nerves"
version = "0.1.0"
description = "Agent Nervous System — Python intelligence layer (5 eyes, coordinator, decomposer, scoring)"
requires-python = ">=3.11"
dependencies = [
    "grpcio>=1.60",
    "grpcio-tools>=1.60",
    "pyarrow>=15",
    "pydantic>=2",
    "httpx>=0.26",
    "tenacity>=8",
    "structlog>=24",
    "numpy>=1.26",
    "sentence-transformers>=2.7",
    "openai>=1.60",
]

[project.optional-dependencies]
dev = [
    "pytest>=8",
    "pytest-asyncio>=0.23",
    "ruff>=0.3",
    "mypy>=1.9",
    "grpcio-testing>=1.60",
]

[tool.ruff]
target-version = "py311"
line-length = 100

[tool.ruff.lint]
select = ["E", "F", "I", "N", "W", "UP", "B", "C4", "SIM"]

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
