"""Tests for decision scoring engine."""

from ans_nerves.scoring.scorer import DecisionScorer, ImmediateOutcome


def test_immediate_success():
    outcome = ImmediateOutcome(action_succeeded=True, results_produced="clicked button")
    assert outcome.score() == 1.0


def test_immediate_timeout():
    outcome = ImmediateOutcome(action_succeeded=False, error_message="timeout after 30s")
    assert outcome.score() == 0.2


def test_immediate_failure():
    outcome = ImmediateOutcome(action_succeeded=False, error_message="element not found")
    assert outcome.score() == 0.0


def test_scorer_success_with_goal_advancement():
    scorer = DecisionScorer()
    score = scorer.score(
        action_succeeded=True,
        results_summary="filled search form",
        error_message=None,
        goal_advanced=True,
    )
    assert score > 0.8


def test_scorer_failure_no_advancement():
    scorer = DecisionScorer()
    score = scorer.score(
        action_succeeded=False,
        results_summary="",
        error_message="selector not found",
        goal_advanced=False,
    )
    assert score < 0.1


def test_short_term_sub_goal_completed():
    from ans_nerves.scoring.scorer import ShortTermOutcome
    outcome = ShortTermOutcome(sub_goal_completed=True)
    assert outcome.score() == 1.0


def test_short_term_criterion_met():
    from ans_nerves.scoring.scorer import ShortTermOutcome
    outcome = ShortTermOutcome(criterion_met="results_visible")
    assert outcome.score() == 0.4


def test_short_term_goal_advanced():
    from ans_nerves.scoring.scorer import ShortTermOutcome
    outcome = ShortTermOutcome(goal_advanced=True)
    assert outcome.score() == 0.7


def test_short_term_no_flags():
    from ans_nerves.scoring.scorer import ShortTermOutcome
    outcome = ShortTermOutcome()
    assert outcome.score() == 0.0


def test_long_term_business_goal_achieved():
    from ans_nerves.scoring.scorer import LongTermOutcome
    lt = LongTermOutcome(business_goal_achieved=True)
    assert lt.score() == 1.0


def test_long_term_metric_value():
    from ans_nerves.scoring.scorer import LongTermOutcome
    lt = LongTermOutcome(metric_name="conversion_rate", metric_value=0.75)
    assert lt.score() == 0.75


def test_long_term_metric_value_clamped():
    from ans_nerves.scoring.scorer import LongTermOutcome
    lt = LongTermOutcome(metric_value=2.5)
    assert lt.score() == 1.0

    lt2 = LongTermOutcome(metric_value=-0.5)
    assert lt2.score() == 0.0


def test_scorer_success_no_goal():
    scorer = DecisionScorer()
    score = scorer.score(
        action_succeeded=True,
        results_summary="done",
        error_message=None,
        goal_advanced=False,
    )
    assert score == 1.0


def test_scorer_partial_goal():
    scorer = DecisionScorer()
    score = scorer.score(
        action_succeeded=False,
        results_summary="",
        error_message="timeout after 30s",
        goal_advanced=True,
    )
    assert 0.0 <= score <= 1.0
