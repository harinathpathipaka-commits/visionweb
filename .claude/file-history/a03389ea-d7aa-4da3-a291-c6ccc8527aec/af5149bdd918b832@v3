class TestScoringConfig:
    def test_weights_sum_check(self):
        with pytest.raises(ValidationError):
            ScoringConfig(immediate_weight=0.9, goal_weight=0.9)

    def test_valid_custom_weights(self):
        cfg = ScoringConfig(
            immediate_weight=0.3,
            goal_weight=0.25,
            efficiency_weight=0.10,
            consistency_weight=0.15,
            business_weight=0.10,
            error_weight=0.10,
        )
        assert cfg.immediate_weight == 0.3

    def test_min_score_out_of_range(self):
        with pytest.raises(ValidationError):
            ScoringConfig(min_score_threshold=1.5)

    def test_default_weights_sum_to_one(self):
        cfg = ScoringConfig()
        total = (
            cfg.immediate_weight + cfg.goal_weight + cfg.efficiency_weight
            + cfg.consistency_weight + cfg.business_weight + cfg.error_weight
        )
        assert abs(total - 1.0) < 0.01


class TestNervesConfig:
    def test_defaults(self):
        cfg = NervesConfig()
        assert cfg.grpc_host == "127.0.0.1"
        assert cfg.grpc_port == 50051

    def test_invalid_port(self):
        with pytest.raises(ValidationError):
            NervesConfig(grpc_port=99999)

    def test_valid_port(self):
        cfg = NervesConfig(grpc_port=50052)
        assert cfg.grpc_port == 50052

    def test_data_dir_default(self):
        cfg = NervesConfig()
        assert cfg.data_dir == Path.home() / ".ans"


