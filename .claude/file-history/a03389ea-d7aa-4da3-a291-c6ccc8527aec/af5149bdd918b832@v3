class TestGetApiKey:
    def test_missing_key_raises(self):
        old = os.getenv("OPENAI_API_KEY")
        if old:
            del os.environ["OPENAI_API_KEY"]
        try:
            with pytest.raises(RuntimeError, match="OPENAI_API_KEY"):
                get_api_key()
        finally:
            if old:
                os.environ["OPENAI_API_KEY"] = old

    def test_key_present_returns_value(self):
        import ans_nerves.config as cfg_mod
        old = os.getenv("OPENAI_API_KEY")
        os.environ["OPENAI_API_KEY"] = "sk-test-12345"
        try:
            assert get_api_key() == "sk-test-12345"
        finally:
            if old:
                os.environ["OPENAI_API_KEY"] = old
            else:
                del os.environ["OPENAI_API_KEY"]


class TestTomlLoading:
    def test_load_toml_file(self, tmp_path):
        from ans_nerves.config import _load_toml
        toml_file = tmp_path / "test.toml"
        toml_file.write_text('[grpc]\nhost = "0.0.0.0"\nport = 9999\n')
        data = _load_toml(toml_file)
        assert data["grpc"]["host"] == "0.0.0.0"
        assert data["grpc"]["port"] == 9999


class TestEnvOverrides:
    def test_grpc_host_override(self):
        from ans_nerves.config import _apply_env_overrides
        data: dict = {}
        with patch.dict(os.environ, {"ANS_GRPC_HOST": "10.0.0.1"}, clear=False):
            _apply_env_overrides(data)
            assert data["grpc_host"] == "10.0.0.1"

    def test_grpc_port_override(self):
        from ans_nerves.config import _apply_env_overrides
        data: dict = {}
        with patch.dict(os.environ, {"ANS_GRPC_PORT": "12345"}, clear=False):
            _apply_env_overrides(data)
            assert data["grpc_port"] == 12345

    def test_data_dir_override(self):
        from ans_nerves.config import _apply_env_overrides
        data: dict = {}
        with patch.dict(os.environ, {"ANS_DATA_DIR": "/custom/path"}, clear=False):
            _apply_env_overrides(data)
            assert data["data_dir"] == Path("/custom/path")

    def test_no_overrides_when_vars_unset(self):
        from ans_nerves.config import _apply_env_overrides
        data: dict = {}
        with patch.dict(os.environ, {}, clear=True):
            if "ANS_GRPC_HOST" in os.environ:
                del os.environ["ANS_GRPC_HOST"]
            if "ANS_GRPC_PORT" in os.environ:
                del os.environ["ANS_GRPC_PORT"]
            if "ANS_DATA_DIR" in os.environ:
                del os.environ["ANS_DATA_DIR"]
            _apply_env_overrides(data)
            assert data == {}


class TestGetConfigWithToml:
    def test_loads_toml_when_present(self, tmp_path):
        import ans_nerves.config as cfg_mod
        toml_file = tmp_path / "ans.toml"
        toml_file.write_text("""
grpc_host = "0.0.0.0"
grpc_port = 10000
data_dir = "/tmp/ans"
""")
        old = cfg_mod._config
        cfg_mod._config = None
        try:
            with patch.dict(os.environ, {"ANS_CONFIG_PATH": str(toml_file)}, clear=False):
                cfg = cfg_mod.get_config()
                assert cfg.grpc_host == "0.0.0.0"
                assert cfg.grpc_port == 10000
        finally:
            cfg_mod._config = old

    def test_env_overrides_toml(self, tmp_path):
        import ans_nerves.config as cfg_mod
        toml_file = tmp_path / "ans.toml"
        toml_file.write_text("""
grpc_host = "0.0.0.0"
grpc_port = 10000
""")
        old = cfg_mod._config
        cfg_mod._config = None
        try:
            with patch.dict(os.environ, {
                "ANS_CONFIG_PATH": str(toml_file),
                "ANS_GRPC_PORT": "55555",
            }, clear=False):
                cfg = cfg_mod.get_config()
                assert cfg.grpc_host == "0.0.0.0"
                assert cfg.grpc_port == 55555
        finally:
            cfg_mod._config = old
