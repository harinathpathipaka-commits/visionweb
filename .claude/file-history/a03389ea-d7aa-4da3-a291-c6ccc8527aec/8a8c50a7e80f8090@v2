async def test_scoring() -> SmokeTestResults:
    """Test 6: Decision Intelligence — scoring and memory store."""
    t0 = time.monotonic()
    try:
        from ans_nerves.scoring.intelligence import ActionRecord, DecisionIntelligence

        intelligence = DecisionIntelligence()

        record = ActionRecord(
            session_id="smoke-test-001",
            goal_id="browser-use-analysis",
            action_type="click",
            selector="a[href*='architecture']",
            tool="browser",
            context_type="github_repo",
            goal_description="Identify browser-use architecture components",
            page_type="github_repo",
            action_succeeded=True,
            results_produced="Architecture section found",
            goal_advanced=True,
            sub_goal_completed=True,
        )
        record_id = intelligence.record_action(record)

        # Query back
        best = intelligence.query_best_actions(
            action_type="click",
            goal_description="Identify browser-use architecture components",
            page_type="github_repo",
            k=3,
        )

        return SmokeTestResults(
            "Decision Intelligence", True, (time.monotonic() - t0) * 1000,
            output={
                "record_id": record_id,
                "total_records": intelligence.total_records,
                "best_actions": [
                    {"action": ba.action_type, "selector": ba.selector,
                     "composite_score": round(ba.composite_score, 4),
                     "distance": round(ba.distance, 4)}
                    for ba in best
                ],
            },
        )
    except Exception as e:
        return SmokeTestResults("Decision Intelligence", False, (time.monotonic() - t0) * 1000, error=str(e))


async def run_full_pipeline() -> FullPipelineResult:
    """Run the full ANS pipeline: Decompose -&gt; Eyes -&gt; Coordinate -&gt; Score."""
    result = FullPipelineResult()

    print("=" * 70)
    print("ANS SMOKE TEST: browser-use Repository Analysis")
    print(f"LLM: {get_config().llm.model} @ {get_config().llm.base_url}")
    print("=" * 70)

    # Phase 1: Decompose
    print("\n[1/6] Decomposer — breaking down analysis task...")
    r = await test_decomposer()
    result.add(r)
    status = "OK" if r.success else "FAIL"
    print(f"  {status} | latency: {r.latency_ms:.0f}ms | tokens: {r.tokens_used} | cost: {r.cost_cents:.2f}¢")
    if r.output:
        subs = len(r.output.get("sub_goals", []))
        print(f"  -&gt; Generated {subs} sub-goals: {[s['description'][:60] for s in r.output.get('sub_goals', [])]}")
    if r.error:
        print(f"  ERROR: {r.error[:200]}")

    # Phase 2: Vision Eye
    print("\n[2/6] Vision Eye — interpreting repo structure...")
    r = await test_vision_eye()
    result.add(r)
    status = "OK" if r.success else "FAIL"
    print(f"  {status} | latency: {r.latency_ms:.0f}ms | tokens: {r.tokens_used} | cost: {r.cost_cents:.2f}¢")
    if r.output:
        print(f"  -&gt; Page type: {r.output.get('page_type')}, elements: {len(r.output.get('visible_elements', []))}")
        print(f"  -&gt; Overlays: {r.output.get('overlays')}, anomalies: {r.output.get('anomalies')}")
    if r.error:
        print(f"  ERROR: {r.error[:200]}")

    # Phase 3: Goal Verifier
    print("\n[3/6] Goal Verifier — checking if architecture info was found...")
    r = await test_verifier_eye()
    result.add(r)
    status = "OK" if r.success else "FAIL"
    print(f"  {status} | latency: {r.latency_ms:.0f}ms | tokens: {r.tokens_used} | cost: {r.cost_cents:.2f}¢")
    if r.output:
        print(f"  -&gt; Criteria met: {r.output.get('criteria_met')}, confidence: {r.output.get('confidence')}")
        print(f"  -&gt; Reasoning: {r.output.get('reasoning', '')[:100]}")
    if r.error:
        print(f"  ERROR: {r.error[:200]}")

    # Phase 4: Error Detector
    print("\n[4/6] Error Detector — classifying missing ANS comparison...")
    r = await test_error_detector()
    result.add(r)
    status = "OK" if r.success else "FAIL"
    print(f"  {status} | latency: {r.latency_ms:.0f}ms | tokens: {r.tokens_used} | cost: {r.cost_cents:.2f}¢")
    if r.output:
        print(f"  -&gt; Failure type: {r.output.get('failure_type')}, should retry: {r.output.get('should_retry')}")
        print(f"  -&gt; Escalation: {r.output.get('escalation_needed')}")
    if r.error:
        print(f"  ERROR: {r.error[:200]}")

    # Phase 5: Coordinator
    print("\n[5/6] Cross-Eye Coordinator — synthesizing all reports...")
    r = await test_coordinator()
    result.add(r)
    status = "OK" if r.success else "FAIL"
    print(f"  {status} | latency: {r.latency_ms:.0f}ms | tokens: {r.tokens_used} | cost: {r.cost_cents:.2f}¢")
    if r.output:
        print(f"  -&gt; Confidence: {r.output.get('confidence')}")
        print(f"  -&gt; Perception: {r.output.get('unified_perception', '')[:150]}")
        print(f"  -&gt; Alerts: {len(r.output.get('alerts', []))}, Contradictions: {len(r.output.get('contradictions', []))}")
    if r.error:
        print(f"  ERROR: {r.error[:200]}")

    # Phase 6: Decision Intelligence
    print("\n[6/6] Decision Intelligence — scoring and storing...")
    r = await test_scoring()
    result.add(r)
    status = "OK" if r.success else "FAIL"
    print(f"  {status} | latency: {r.latency_ms:.0f}ms")
    if r.output:
        print(f"  -&gt; Record ID: {r.output.get('record_id')}, total: {r.output.get('total_records')}")
        best = r.output.get('best_actions', [])
        for ba in best:
            print(f"  -&gt; Best: {ba['action']} @ {ba['selector']} score={ba['composite_score']} dist={ba['distance']}")
    if r.error:
        print(f"  ERROR: {r.error[:200]}")

    # Summary
    result.overall_success = all(r.success for r in result.results)
    print("\n" + "=" * 70)
    print("FULL PIPELINE SUMMARY")
    print("=" * 70)
    print(f"  Components: {len(result.results)} run, {sum(1 for r in result.results if r.success)} passed, "
          f"{sum(1 for r in result.results if not r.success)} failed")
    print(f"  Total latency: {result.total_latency_ms:.0f}ms ({result.total_latency_ms/1000:.1f}s)")
    print(f"  Total tokens: {result.total_tokens}")
    print(f"  Total cost: {result.total_cost_cents:.2f}¢")
    print(f"  Overall: {'ALL PASSED' if result.overall_success else 'SOME FAILED'}")

    if not result.overall_success:
        print("\nFAILURES:")
        for r in result.results:
            if not r.success:
                print(f"  - {r.component}: {r.error}")

    return result


def main() -> int:
    result = asyncio.run(run_full_pipeline())
    return 0 if result.overall_success else 1


if __name__ == "__main__":
    sys.exit(main())
