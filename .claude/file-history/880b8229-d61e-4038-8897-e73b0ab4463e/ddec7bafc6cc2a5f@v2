name: CI — MCP Server

on:
  push:
    branches: [master, main]
    paths:
      - 'packages/mcp-server/**'
      - '.github/workflows/ci-mcp-server.yml'
  pull_request:
    branches: [master, main]
    paths:
      - 'packages/mcp-server/**'

jobs:
  build-and-test:
    name: Build & Test
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'
          cache-dependency-path: packages/mcp-server/package-lock.json

      - name: Install dependencies
        working-directory: packages/mcp-server
        run: npm ci

      - name: Type check
        working-directory: packages/mcp-server
        run: npx tsc --noEmit

      - name: Run tests
        working-directory: packages/mcp-server
        run: npm test

      - name: Build
        working-directory: packages/mcp-server
        run: npm run build
