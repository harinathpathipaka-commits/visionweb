# ── Dataset loading (once, at import) ──────────────────────────────────────

_DATASET_PATH = os.path.join(os.path.dirname(__file__), "..", "WA_Fn-UseC_-Telco-Customer-Churn.csv")


def _load_rows() -> List[dict]:
    with open(_DATASET_PATH, "r", encoding="utf-8") as f:
        return list(csv.DictReader(f))


_ROWS = _load_rows()
_TENURE = [float(r["tenure"]) for r in _ROWS]
_MONTHLY = [float(r["MonthlyCharges"]) for r in _ROWS]
_TOTAL = [float(r["TotalCharges"]) if r["TotalCharges"].strip() else 0.0 for r in _ROWS]
_CHURN_BINARY = [1.0 if r["Churn"] == "Yes" else 0.0 for r in _ROWS]


def _churn_rate_by_bucket(x_vals: List[float], y_vals: List[float], n_buckets: int = 7) -> List[Tuple[float, float]]:
    """Compute ground-truth churn rate per bucket (bucket_center, churn_rate)."""
    sorted_pairs = sorted(zip(x_vals, y_vals))
    bucket_size = len(sorted_pairs) // n_buckets
    result = []
    for i in range(n_buckets):
        start = i * bucket_size
        end = start + bucket_size if i < n_buckets - 1 else len(sorted_pairs)
        bucket = sorted_pairs[start:end]
        center = sum(p[0] for p in bucket) / len(bucket)
        rate = sum(p[1] for p in bucket) / len(bucket) * 100
        result.append((center, rate))
    return result


