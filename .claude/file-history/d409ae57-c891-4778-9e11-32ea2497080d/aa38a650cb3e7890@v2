from __future__ import annotations

from typing import Any, Dict, List, Optional, Tuple

import numpy as np


def explain_drivers(
    fit_result: Dict[str, Any],
    data_summary: Optional[Dict[str, Any]] = None,
    top_n: int = 5,
) -> Dict[str, Any]:
    """Generate a structured explanation of what drives an outcome.

    Takes a fit_multivariate() result dict and produces human-readable insights.
    """
    importance = fit_result.get("variable_importance", {})
    coefficients = fit_result.get("coefficients", {})
    p_values = fit_result.get("p_values", {})
    adj_r2 = fit_result.get("adj_r2", 0.0)
    n_obs = fit_result.get("n_obs", 0)

    if not importance:
        return {"summary": "No model available.", "drivers": [], "model_quality": "none"}

    # Sort drivers by importance
    sorted_drivers = sorted(importance.items(), key=lambda x: x[1], reverse=True)
    top_drivers = sorted_drivers[:top_n]

    # Driver details
    drivers = []
    for name, imp in top_drivers:
        coeff = coefficients.get(name, 0.0)
        p_val = p_values.get(name, 1.0)
        significance = "significant" if p_val < 0.05 else "marginal" if p_val < 0.10 else "not significant"

        direction = "increases" if coeff > 0 else "decreases"
        drivers.append({
            "variable": name,
            "importance": round(imp, 4),
            "coefficient": round(coeff, 4),
            "direction": direction,
            "p_value": round(p_val, 4),
            "significance": significance,
            "interpretation": f"'{name}' {direction} the target{' (significant)' if significance == 'significant' else ''}. "
                              f"A 1-unit increase in '{name}' changes the target by {coeff:+.4f}.",
        })

    # Model quality
    if adj_r2 > 0.7:
        quality = "strong"
        quality_note = "The model explains most of the variation."
    elif adj_r2 > 0.4:
        quality = "moderate"
        quality_note = "The model captures meaningful patterns but significant variation remains unexplained."
    elif adj_r2 > 0.1:
        quality = "weak"
        quality_note = "The relationship is detectable but noisy. Consider additional variables."
    else:
        quality = "negligible"
        quality_note = "No meaningful relationship found with these variables."

    # Bulk of explained variance
    cum_imp = sum(d["importance"] for d in drivers)
    top3 = sum(d["importance"] for d in drivers[:3])
    top3_pct = round(100 * top3 / cum_imp, 1) if cum_imp > 0 else 0

    summary = (
        f"Model explains {adj_r2*100:.1f}% of variation (n={n_obs}). "
        f"Top {min(3, len(drivers))} drivers explain {top3_pct}% of modeled variance. "
        f"{quality_note}"
    )

    return {
        "summary": summary,
        "model_quality": quality,
        "adj_r2": round(adj_r2, 4),
        "n_obs": n_obs,
        "drivers": drivers,
        "all_drivers_ranked": [{"variable": name, "importance": round(imp, 4)}
                               for name, imp in sorted_drivers],
    }


def compare_scenarios(
    fit_result: Dict[str, Any],
    scenarios: List[Dict[str, Any]],  # [{name: str, values: Dict[str, float]}]
) -> Dict[str, Any]:
    """Compare multiple what-if scenarios using fitted coefficients.

    Returns predicted outcome for each scenario + deltas.
    """
    from .multivar import predict_multivariate

    coefficients = fit_result.get("coefficients", {})
    if not coefficients:
        return {"error": "No model coefficients available.", "scenarios": []}

    results = []
    baseline = None
    for sc in scenarios:
        pred = predict_multivariate(sc.get("values", {}), coefficients)
        results.append({
            "name": sc.get("name", "scenario"),
            "values": sc.get("values", {}),
            "prediction": round(pred, 4),
        })
        if baseline is None:
            baseline = pred

    # Add deltas from first scenario
    if baseline is not None:
        for r in results:
            delta = r["prediction"] - baseline
            r["delta"] = round(delta, 4)
            r["delta_pct"] = round(100 * delta / baseline, 2) if abs(baseline) > 1e-10 else None

    return {
        "scenarios": results,
        "baseline_name": scenarios[0]["name"] if scenarios else None,
    }


def generate_prose(fit_result: Dict[str, Any]) -> str:
    """Generate narrative prose from a fit result."""
    explanation = explain_drivers(fit_result)
    if explanation["model_quality"] == "none":
        return "No model to explain."

    drivers = explanation["drivers"]
    if not drivers:
        return explanation["summary"]

    prose = explanation["summary"] + "\n\n"
    for d in drivers:
        prose += f"- {d['interpretation']}\n"

    return prose.strip()
