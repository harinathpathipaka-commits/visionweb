class TestEdgeCaseInputs:
    def test_extremely_small_values(self, client):
        """Values near float minimum — numerical range check prevents underflow crashes."""
        x = [1e-100, 2e-100, 3e-100, 4e-100, 5e-100]
        y = [2e-100, 4e-100, 6e-100, 8e-100, 10e-100]
        r = client.post("/v1/solve", json={"query": "test", "x_values": x, "y_values": y})
        assert r.status_code != 500, f"Small values caused 500: {r.text}"

    def test_extremely_large_values(self, client):
