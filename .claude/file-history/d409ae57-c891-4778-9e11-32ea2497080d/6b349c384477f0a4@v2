    def test_multiple_solves_all_have_valid_schemas(self, client):
        for i in range(5):
            x, y = _linear_data(10 + i)
            r = client.post("/v1/solve", json={
                "query": f"test_{i}", "x_values": x, "y_values": y,
            })
            assert r.status_code == 200
            data = r.json()
            assert set(data.keys()) == SOLVE_FIELDS
            assert len(data["trace_id"]) > 0

    def test_unique_trace_ids(self, client):
        x, y = _linear_data()
        trace_ids = set()
        for _ in range(3):
            r = client.post("/v1/solve", json={"query": "unique test", "x_values": x, "y_values": y})
            trace_ids.add(r.json()["trace_id"])
        assert len(trace_ids) == 3
