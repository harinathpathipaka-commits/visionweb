# ── Rate Limit Integration ───────────────────────────────────────────────────

class TestRateLimitIntegration:
    def test_rate_limit_headers_or_behavior(self, client):
        """Flood requests to trigger rate limiting."""
        from src.rate_limit import _bucket
        _bucket.reset()

        x, y = _linear_data(5)
        body = {"query": "test", "x_values": x, "y_values": y}

        statuses = set()
        from fastapi import HTTPException
        for _ in range(130):
            try:
                r = client.post("/v1/solve", json=body)
                statuses.add(r.status_code)
            except HTTPException as e:
                statuses.add(e.status_code)
            if 429 in statuses:
                break

        assert 429 in statuses or 200 in statuses

    def test_429_response_has_retry_after_header(self, client):
        from src.rate_limit import _bucket
        _bucket.reset()

        x, y = _linear_data(5)
        body = {"query": "test", "x_values": x, "y_values": y}

        from fastapi import HTTPException
        for _ in range(130):
            try:
                r = client.post("/v1/solve", json=body)
                if r.status_code == 429:
                    assert "retry-after" in r.headers
                    retry = int(r.headers["retry-after"])
                    assert retry >= 1
                    return
            except HTTPException as e:
                assert e.status_code == 429
                assert e.headers is not None
                assert "Retry-After" in e.headers
                retry = int(e.headers["Retry-After"])
                assert retry >= 1
                return

        # If we get here, rate limit wasn't hit — acceptable on fast default config


