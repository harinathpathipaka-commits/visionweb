        assert isinstance(data["trace_id"], str)
        assert len(data["trace_id"]) > 0

    def test_parameters_is_dict_str_float(self, client):
        x, y = _linear_data()
        data = client.post("/v1/solve", json={"query": "test", "x_values": x, "y_values": y}).json()
        params = data["parameters"]
        assert isinstance(params, dict)
        for k, v in params.items():
            assert isinstance(k, str)
            assert isinstance(v, float)

    def test_numeric_fields_are_floats(self, client):
        x, y = _linear_data()
        data = client.post("/v1/solve", json={"query": "test", "x_values": x, "y_values": y}).json()
        for field in ("answer", "uncertainty_std", "ci_95_lower", "ci_95_upper", "r2_adj"):
            assert isinstance(data[field], (float, int)), f"{field} is {type(data[field])}"

    def test_gate_passed_is_boolean(self, client):
        x, y = _linear_data()
        data = client.post("/v1/solve", json={"query": "test", "x_values": x, "y_values": y}).json()
        assert isinstance(data["gate_passed"], bool)

    def test_prose_is_nonempty_string(self, client):
        x, y = _linear_data()
        data = client.post("/v1/solve", json={"query": "test", "x_values": x, "y_values": y}).json()
        assert isinstance(data["prose"], str)
        assert len(data["prose"]) > 0

    def test_ci_bounds_ordered(self, client):
        x, y = _linear_data()
        data = client.post("/v1/solve", json={"query": "test", "x_values": x, "y_values": y}).json()
        assert data["ci_95_lower"] <= data["ci_95_upper"]

    def test_no_query_returns_422(self, client):
        x, _ = _linear_data(5)
        r = client.post("/v1/solve", json={"x_values": x, "y_values": x})
        assert r.status_code == 422

    def test_empty_x_values_returns_422(self, client):
        r = client.post("/v1/solve", json={"query": "q", "x_values": [], "y_values": [1.0, 2.0, 3.0]})
        assert r.status_code == 422

    def test_mismatched_lengths_validated(self, client):
        """Pydantic validates min_length=3 on each list before endpoint code runs."""
        r = client.post("/v1/solve", json={
            "query": "q", "x_values": [1.0, 2.0, 3.0], "y_values": [4.0, 5.0],
        })
        # y_values has only 2 entries — fails min_length=3 → 422
        assert r.status_code == 422

    def test_equal_lengths_but_both_too_short(self, client):
        """Both arrays pass length check but fail min_length=3."""
        r = client.post("/v1/solve", json={
            "query": "q", "x_values": [1.0, 2.0], "y_values": [3.0, 4.0],
        })
        assert r.status_code == 422

    def test_excessively_long_query_rejected(self, client):
        x, y = _linear_data(5)
        long_q = "x" * 5000
        r = client.post("/v1/solve", json={"query": long_q, "x_values": x, "y_values": y})
        assert r.status_code == 422

    def test_string_in_x_values_rejected(self, client):
        r = client.post("/v1/solve", json={
            "query": "test", "x_values": ["a", "b", "c"], "y_values": [1.0, 2.0, 3.0],
        })
        assert r.status_code == 422

    def test_nan_in_input_accepted_by_pydantic(self, client):
        """NaN in input data must be rejected with 422 now that validator rejects non-finite."""
        import json as _json
        body = _json.dumps({
            "query": "test", "x_values": [float("nan"), 2.0, 3.0], "y_values": [1.0, 2.0, 3.0],
        }, allow_nan=True)
        r = client.post("/v1/solve", content=body, headers={"Content-Type": "application/json"})
        assert r.status_code == 422, f"NaN should be 422, got {r.status_code}"

    def test_inf_in_input_accepted_by_pydantic(self, client):
        """Inf in input data must be rejected with 422 now that validator rejects non-finite."""
        import json as _json
        body = _json.dumps({
            "query": "test", "x_values": [float("inf"), 2.0, 3.0], "y_values": [1.0, 2.0, 3.0],
        }, allow_nan=True)
        r = client.post("/v1/solve", content=body, headers={"Content-Type": "application/json"})
        assert r.status_code == 422, f"Inf should be 422, got {r.status_code}"


