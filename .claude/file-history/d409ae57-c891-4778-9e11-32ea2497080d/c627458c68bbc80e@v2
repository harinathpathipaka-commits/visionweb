class TestCausalAPI:
    def test_granger_endpoint(self, client):
        rng = __import__("numpy").random.default_rng(42)
        n = 150
        x = [0.0] * n
        y = [0.0] * n
        for t in range(1, n):
            x[t] = 0.7 * x[t-1] + float(rng.normal(0, 0.1))
            y[t] = 0.5 * y[t-1] + 0.3 * x[t-1] + float(rng.normal(0, 0.1))
        resp = client.post("/v2/causal/granger", json={"x": x, "y": y, "max_lag": 3})
        assert resp.status_code == 200
        data = resp.json()
        assert "causal" in data


