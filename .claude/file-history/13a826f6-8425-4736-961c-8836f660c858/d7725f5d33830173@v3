### 7. `crates/ans-cdp/src/client.rs` — Replace get_distilled_dom stub

Replace the current stub that returns empty `DistilledPage` with:
```rust
async fn get_distilled_dom(&self, mode: DistillMode) -> Result<DistilledPage, BrowserError> {
    // 1. Fetch full DOM tree
    let doc_result = self.connection
        .send_command(command::dom_get_document(-1), Duration::from_secs(10))
        .await?;
    
    // 2. Get page title
    let title = self.connection
        .send_command(command::runtime_evaluate("document.title"), Duration::from_secs(3))
        .await
        .ok()
        .and_then(|v| v.as_str().map(String::from))
        .unwrap_or_default();
    
    let url = self.current_url.lock().await.clone();
    
    // 3. Distill
    let distiller = ans_distill::Distiller;
    Ok(distiller.process(&doc_result, mode, &url, &title))
}
```

Add `use ans_distill::Distiller;` at top.

