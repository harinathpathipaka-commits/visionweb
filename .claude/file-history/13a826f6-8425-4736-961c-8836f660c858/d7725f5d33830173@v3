### 9. `crates/ans-ipc/src/server.rs` — Wire up 3 Phase 2 RPCs

Replace the 3 `Status::unimplemented(...)` stubs with real implementations:

**get_distilled_dom:**
```rust
async fn get_distilled_dom(&self, request: Request<DomRequest>) 
    -> Result<Response<DistilledDom>, Status> 
{
    let req = request.into_inner();
    let session_id = parse_uuid(&req.session_id, "session_id")?;
    let mode = parse_distill_mode(&req.mode)?;
    
    let sessions = self.sessions.read().await;
    let handle = sessions.get(&session_id)
        .ok_or_else(|| Status::not_found("session not found"))?;
    
    let page = handle.backend.get_distilled_dom(mode).await
        .map_err(|e| Status::internal(e.to_string()))?;
    
    Ok(Response::new(ans_distill::serialization::distilled_page_to_proto(&page)))
}
```

**capture_screenshot:**
```rust
async fn capture_screenshot(&self, request: Request<ScreenshotRequest>)
    -> Result<Response<ScreenshotResponse>, Status>
{
    let req = request.into_inner();
    let session_id = parse_uuid(&req.session_id, "session_id")?;
    let format = match req.format.as_str() {
        "jpeg" => ImageFormat::Jpeg { quality: req.quality.clamp(1, 100) as u8 },
        _ => ImageFormat::Png,
    };
    
    let sessions = self.sessions.read().await;
    let handle = sessions.get(&session_id)
        .ok_or_else(|| Status::not_found("session not found"))?;
    
    let bytes = handle.backend.capture_screenshot(format, req.full_page).await
        .map_err(|e| Status::internal(e.to_string()))?;
    
    Ok(Response::new(ScreenshotResponse {
        success: true,
        size_bytes: bytes.len() as i64,
        width: 0,  // CDP doesn't return dimensions inline
        height: 0,
        format: req.format,
        data: bytes,
        arrow_shm_key: String::new(),
    }))
}
```

**compute_diff:**
```rust
async fn compute_diff(&self, request: Request<DiffRequest>)
    -> Result<Response<DiffReport>, Status>
{
    let req = request.into_inner();
    let before = req.before
        .ok_or_else(|| Status::invalid_argument("before is required"))?;
    let after = req.after
        .ok_or_else(|| Status::invalid_argument("after is required"))?;
    
    let before_page = ans_distill::serialization::proto_to_distilled_page(&before);
    let after_page = ans_distill::serialization::proto_to_distilled_page(&after);
    
    let differ = ans_diff::PageDiffer;
    let output = differ.diff(&before_page, &after_page);
    
    Ok(Response::new(DiffReport {
        before_url: before_page.url,
        after_url: after_page.url,
        is_same_page: output.is_same_page,
        added: output.added.into_iter().map(|c| ans_proto::ans::ElementChange { ... }).collect(),
        removed: output.removed.into_iter().map(|c| ans_proto::ans::ElementChange { ... }).collect(),
        modified: output.modified.into_iter().map(|m| ans_proto::ans::ElementModification { ... }).collect(),
        visual_diff_percentage: output.visual_diff_pct,
        summary: output.summary,
    }))
}
```

**Note:** The SessionManager currently uses `RwLock<HashMap<>>` — the `sessions` field is private. We need to either:
- Add accessor methods to SessionManager: `get_backend(session_id) -> Option<&CdpBackend>`, `get_distilled_dom(session_id, mode)`, etc.
- OR expose the sessions map
- Best approach: add methods to SessionManager that delegate to the backend directly

Add these methods to `ans-ipc/src/session.rs`:
