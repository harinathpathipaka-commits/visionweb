apiVersion: v1
kind: Service
metadata:
  name: valkey
  labels:
    app: equation-layer
    component: valkey
spec:
  clusterIP: None
  ports:
    - port: 6379
      targetPort: 6379
      name: redis
  selector:
    app: equation-layer
    component: valkey
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: valkey
  labels:
    app: equation-layer
    component: valkey
spec:
  serviceName: valkey
  replicas: 1
  selector:
    matchLabels:
      app: equation-layer
      component: valkey
  template:
    metadata:
      labels:
        app: equation-layer
        component: valkey
    spec:
      containers:
        - name: valkey
          image: valkey/valkey:7-alpine
          command: ["valkey-server"]
          args: ["--appendonly", "yes", "--save", "60", "1"]
          ports:
            - containerPort: 6379
              name: redis
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 256Mi
          volumeMounts:
            - name: valkey-data
              mountPath: /data
  volumeClaimTemplates:
    - metadata:
        name: valkey-data
      spec:
        accessModes: ["ReadWriteOnce"]
        resources:
          requests:
            storage: 5Gi
