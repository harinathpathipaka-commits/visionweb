from dataclasses import dataclass


@dataclass(frozen=True)
class Thresholds:
    min_obs: int = 15
    min_r2_adj: float = 0.6
    max_holdout_mape: float = 0.2


@dataclass(frozen=True)
class AppConfig:
    thresholds: Thresholds = Thresholds()
    time_split_ratio: float = 0.2


CONFIG = AppConfig()
