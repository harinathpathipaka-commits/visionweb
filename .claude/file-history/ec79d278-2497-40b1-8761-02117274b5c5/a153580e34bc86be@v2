[package]
name = "el_ledger"
version = "0.1.0"
edition = "2021"

[lib]
name = "el_ledger"
crate-type = ["cdylib", "rlib"]

[dependencies]
pyo3 = { version = "0.21", features = ["extension-module"], optional = true }
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
rusqlite = { version = "0.31", features = ["bundled"] }

[features]
python = ["pyo3"]
