from __future__ import annotations

from dataclasses import dataclass
from typing import Dict, List, Optional

import numpy as np

from .models import EquationFit, FitStats


@dataclass(frozen=True)
class PySRResult:
    equation: EquationFit


def run_pysr(
    x: List[float],
    y: List[float],
    niterations: int = 40,
    binary_operators: Optional[List[str]] = None,
    unary_operators: Optional[List[str]] = None,
) -> Optional[PySRResult]:
    try:
        from pysr import PySRRegressor  # type: ignore
    except ImportError:
        return None

    if binary_operators is None:
        binary_operators = ["+", "*", "-", "/", "^"]
    if unary_operators is None:
        unary_operators = ["exp", "log", "sin", "cos"]

    x_arr = np.array(x, dtype=np.float64).reshape(-1, 1)
    y_arr = np.array(y, dtype=np.float64)

    try:
        model = PySRRegressor(
            niterations=niterations,
            binary_operators=binary_operators,
            unary_operators=unary_operators,
            model_selection="best",
            verbosity=0,
            progress=False,
        )
        model.fit(x_arr, y_arr)

        if model.equations_ is None or len(model.equations_) == 0:
            return None

        best = model.equations_.iloc[0]
        sympy_expr = str(best["equation"]) if "equation" in best else ""

        y_pred = model.predict(x_arr)
        ss_res = np.sum((y_arr - y_pred) ** 2)
        ss_tot = np.sum((y_arr - np.mean(y_arr)) ** 2)
        r2 = 1.0 - ss_res / ss_tot if ss_tot > 0 else 0.0
        n = len(y_arr)
        r2_adj = 1.0 - (1.0 - r2) * (n - 1) / max(n - 2, 1)

        residuals = y_arr - y_pred.flatten()
        holdout_mape = float(np.mean(np.abs(residuals / (np.abs(y_arr) + 1e-10))) * 100)

        params: Dict[str, float] = {}
        for col in best.index:
            if col not in ("equation", "complexity", "loss", "score") and isinstance(best[col], (int, float, np.floating, np.integer)):
                params[col] = float(best[col])
        if not params:
            params = {"a": 1.0}

        stats = FitStats(
            r2_adj=r2_adj,
            holdout_mape=holdout_mape,
            aic=float(best.get("loss", 100.0)),
            residual_random=True,
            n_obs=n,
        )

        equation = EquationFit(
            family="pysr",
            parameters=params,
            stats=stats,
            sympy_expr=sympy_expr if sympy_expr else "y = x",
        )
        return PySRResult(equation=equation)

    except Exception:
        return None


def run_pysr_primary(x: List[float], y: List[float]) -> PySRResult:
    result = run_pysr(x, y)
    if result is not None:
        return result

    n_obs = len(x)
    stats = FitStats(
        r2_adj=0.0,
        holdout_mape=float("inf"),
        aic=float("inf"),
        residual_random=False,
        n_obs=n_obs,
    )
    equation = EquationFit(
        family="pysr_unavailable",
        parameters={"a": 0.0},
        stats=stats,
        sympy_expr="y = 0",
    )
    return PySRResult(equation=equation)
