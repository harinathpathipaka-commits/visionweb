import pytest
from src.compute import (
    evaluate_equation, symbolic_derivatives, sensitivity_map,
)
from src.models import EquationFit, FitStats, ComputeResult


def _make_eq(expr="2*x + 1", family="linear", a=2.0, b=1.0):
    return EquationFit(
        family=family,
        parameters={"a": a, "b": b},
        stats=FitStats(r2_adj=0.95, holdout_mape=0.05, aic=80.0, residual_random=True, n_obs=20),
        sympy_expr=expr,
    )


class TestEvaluateEquation:
    def test_simple_linear(self):
        eq = _make_eq("2*x + 1")
        result = evaluate_equation(eq, x_value=1.0)
        assert isinstance(result, ComputeResult)
        assert abs(result.answer - 3.0) < 1e-10

    def test_evaluate_at_point(self):
        eq = _make_eq("a*x + b")
        result = evaluate_equation(eq, x_value=0.0)
        assert abs(result.answer - 1.0) < 1e-10

    def test_polynomial(self):
        eq = _make_eq("x**2 + 3*x + 2")
        result = evaluate_equation(eq, x_value=1.0)
        assert abs(result.answer - 6.0) < 1e-10

    def test_returns_metadata(self):
        eq = _make_eq("x + 1")
        result = evaluate_equation(eq, x_value=0.0)
        assert isinstance(result.answer, float)
        assert len(result.derivatives) > 0
        assert len(result.curvature) > 0

    def test_invalid_expression_raises(self):
        eq = EquationFit(
            family="linear",
            parameters={"a": 1.0},
            stats=FitStats(r2_adj=0.0, holdout_mape=1.0, aic=999.0, residual_random=False, n_obs=5),
            sympy_expr="invalid_syntax***",
        )
        with pytest.raises(Exception):
            evaluate_equation(eq, x_value=1.0)


class TestSymbolicDerivatives:
    def test_first_derivative_linear(self):
        eq = _make_eq("a*x + b")
        derivs = symbolic_derivatives(eq)
        assert "expression" in derivs
        assert "first_derivative" in derivs
        assert "second_derivative" in derivs

    def test_polynomial_derivatives(self):
        eq = _make_eq("x**2")
        derivs = symbolic_derivatives(eq)
        assert "first_derivative" in derivs
        assert "second_derivative" in derivs


class TestSensitivityMap:
    def test_sensitivity_at_point(self):
        eq = _make_eq("2*x + 1")
        sens = sensitivity_map(eq, x_value=1.0)
        assert isinstance(sens, dict)
        assert "derivative_at_point" in sens
        assert "elasticity_approx" in sens

    def test_empty_derivatives(self):
        eq = _make_eq("x")
        sens = sensitivity_map(eq, x_value=1.0)
        assert "derivative_at_point" in sens
