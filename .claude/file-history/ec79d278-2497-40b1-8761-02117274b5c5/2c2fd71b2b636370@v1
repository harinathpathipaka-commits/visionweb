from __future__ import annotations

from dataclasses import dataclass
from typing import Dict, List

from .models import EquationFit, FitStats


@dataclass(frozen=True)
class PySRResult:
    equation: EquationFit


def run_pysr_primary(x: List[float], y: List[float]) -> PySRResult:
    n_obs = len(x)
    stats = FitStats(
        r2_adj=0.78,
        holdout_mape=0.12,
        aic=118.0,
        residual_random=True,
        n_obs=n_obs,
    )
    equation = EquationFit(
        family="pysr",
        parameters={"a": 1.2, "b": -0.9},
        stats=stats,
        sympy_expr="y=a*x**b",
    )
    return PySRResult(equation=equation)
