# ── Data Round-Trip Integrity ─────────────────────────────────────────────

class TestDataRoundTrip:
    def test_equation_store_and_retrieve(self):
        db_path = str(Path(tempfile.gettempdir()) / f"test_roundtrip_{os.getpid()}.db")
        try:
            init_storage(db_path)
            now = "2024-06-01T12:00:00"
            var_hash = "finance:revenue:cost"
            domain = "finance"

            eq_id = get_or_create_equation(db_path, var_hash, domain, now)
            assert eq_id > 0

            version_id = insert_version(
                db_path=db_path, equation_id=eq_id, form_family="linear",
                sympy_ast="2.5*x + 100", parameters={"a": 2.5, "b": 100.0},
                stats={"r2_adj": 0.97, "holdout_mape": 2.0, "aic": 50.0, "residual_random": True, "n_obs": 60},
                n_obs=60, created_at=now, source="primary", provenance={"source": "roundtrip_test"},
            )
            record_shadow_eval(db_path, version_id, mape=2.0, aic=50.0,
                              residual_random=True, passed=True, evaluated_at=now)
            promote_version(db_path, eq_id, version_id, now, "roundtrip_test")

            # Retrieve and verify
            entry = find_equation(db_path, var_hash, domain)
            assert entry is not None
            assert entry["form_family"] == "linear"
            assert entry["sympy_ast"] == "2.5*x + 100"
            assert entry["parameters"] == {"a": 2.5, "b": 100.0}
            stats = entry["stats"]
            assert stats["r2_adj"] == 0.97
            assert stats["n_obs"] == 60
            assert entry["drift_status"] == "pending"
        finally:
            try:
                os.unlink(db_path)
            except PermissionError:
                pass

