# ── Schema Integrity ──────────────────────────────────────────────────────

class TestSchemaIntegrity:
    def test_all_tables_have_expected_columns(self):
        db_path = str(Path(tempfile.gettempdir()) / f"test_schema_{os.getpid()}.db")
        try:
            init_storage(db_path)
            init_ledger(db_path)

            expected = {
                "equation_library": {"equation_id", "var_hash", "domain", "active_version_id",
                                    "form_family", "sympy_ast", "parameters_json", "stats_json",
                                    "n_obs", "drift_status", "confidence_level"},
                "equation_versions": {"version_id", "equation_id", "form_family", "sympy_ast",
                                     "parameters_json", "stats_json", "n_obs", "source",
                                     "shadow_status", "provenance_json"},
                "equation_shadow_evals": {"shadow_eval_id", "version_id", "mape", "aic",
                                         "residual_random", "passed", "evaluated_at"},
                "observation_ledger": {"observation_id", "variable", "value", "unit",
                                      "timestamp", "entity_id", "quality_score",
                                      "provenance_json"},
                "ingestion_files": {"file_id", "filename", "content_type", "size_bytes",
                                   "checksum"},
                "ingestion_jobs": {"job_id", "file_id", "status", "total_rows",
                                  "observations_created", "issues_count"},
                "epistemic_ledger": {"event_id", "trace_id", "event_type", "payload_json",
                                    "created_at"},
            }

            conn = sqlite3.connect(db_path)
            try:
                for table_name, expected_cols in expected.items():
                    rows = conn.execute(f"PRAGMA table_info({table_name})").fetchall()
                    actual_cols = {r[1] for r in rows}
                    missing = expected_cols - actual_cols
                    assert not missing, f"Table {table_name}: missing columns {missing}"
            finally:
                conn.close()
        finally:
            try:
                os.unlink(db_path)
            except PermissionError:
                pass

    def test_timestamps_use_iso_format(self):
        db_path = str(Path(tempfile.gettempdir()) / f"test_timestamps_{os.getpid()}.db")
        try:
            init_ledger(db_path)
