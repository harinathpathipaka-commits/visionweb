# ── Ledger Integrity ──────────────────────────────────────────────────────

class TestLedgerIntegrity:
    def test_init_ledger_creates_table_idempotently(self):
        db_path = str(Path(tempfile.gettempdir()) / f"test_ledger_init_{os.getpid()}.db")
        try:
            init_ledger(db_path)
            init_ledger(db_path)  # idempotent

            conn = sqlite3.connect(db_path)
            try:
                tables = conn.execute(
                    "SELECT name FROM sqlite_master WHERE type='table' AND name='epistemic_ledger'"
                ).fetchone()
                assert tables is not None
            finally:
                conn.close()
        finally:
            try:
                os.unlink(db_path)
            except PermissionError:
                pass

    def test_append_and_list_events(self):
        db_path = str(Path(tempfile.gettempdir()) / f"test_ledger_append_{os.getpid()}.db")
        trace_id = str(uuid.uuid4())
        try:
            init_ledger(db_path)
            append_event(db_path, trace_id, "test_start", '{"key": "value"}')
            append_event(db_path, trace_id, "test_end", '{"result": "ok"}')

            events = list_events(db_path, trace_id)
            assert len(events) == 2
            assert events[0]["event_type"] == "test_start"
            assert events[0]["payload_json"] == '{"key": "value"}'
            assert events[1]["event_type"] == "test_end"
            assert "created_at" in events[0]
        finally:
