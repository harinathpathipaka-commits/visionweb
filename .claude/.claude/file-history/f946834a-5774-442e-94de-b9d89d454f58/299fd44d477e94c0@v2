# ── Full Pipeline Ledger Trace ────────────────────────────────────────────

class TestPipelineLedgerTrace:
    def test_solve_produces_ledger_events(self):
        """A solve call should produce multiple ledger events with a trace_id."""
        from src.pipeline import solve

        db_path = str(Path(tempfile.gettempdir()) / f"test_pipeline_ledger_{os.getpid()}.db")
        try:
            x = [float(i) for i in range(20)]
            y = [float(i * 2 + 1) for i in range(20)]

            result = solve(
                query="What is the linear relationship?",
                x_values=x,
                y_values=y,
                db_path=db_path,
            )

            assert result.trace_id is not None
            assert len(result.trace_id) > 0

            init_ledger(db_path)
            events = list_events(db_path, result.trace_id)
            # Should have at least: domain_routing, extraction, correlation, library_miss/fitting, compute, probabilistic, gate
            assert len(events) >= 6

            event_types = {e["event_type"] for e in events}
            assert "domain_routing" in event_types
            assert "extraction" in event_types
            assert "correlation" in event_types
            assert "gate" in event_types
        finally:
            try:
                os.unlink(db_path)
            except PermissionError:
                pass

    def test_all_events_have_same_trace_id(self):
        from src.pipeline import solve

        db_path = str(Path(tempfile.gettempdir()) / f"test_trace_consistency_{os.getpid()}.db")
        try:
            x = [float(i) for i in range(20)]
            y = [float(i * 2 + 1) for i in range(20)]

            result = solve(
                query="Test trace consistency",
                x_values=x,
                y_values=y,
                db_path=db_path,
            )

            events = list_events(db_path, result.trace_id)
            assert len(events) > 0
            for ev in events:
                # All events are retrieved by the same trace_id, so this is implicit
                assert result.trace_id is not None

            # Different solve calls get different trace_ids
            result2 = solve(query="Another test", x_values=x, y_values=y, db_path=db_path)
            assert result.trace_id != result2.trace_id
        finally:
            try:
                os.unlink(db_path)
            except PermissionError:
                pass

    def test_ledger_contains_valid_json_payloads(self):
