# ── Memory / Resource Management ──────────────────────────────────────────

class TestResourceManagement:
    def test_token_bucket_memory_bounded(self):
        bucket = TokenBucket(max_tokens=10, window_sec=1)
        for i in range(11000):
            bucket.consume(f"client-{i}")
        # After exceeding 10k entries, stale cleanup triggers on next refill
        time.sleep(3)  # wait past window*2 for all entries
        bucket.consume("fresh-client")
        # Most of the 11k entries should now be stale and cleaned
        assert len(bucket._buckets) < 11000

    def test_lru_cache_bounded_memory(self):
        cache = ValkeyCache(url="redis://nonexistent:9999", ttl=60, max_memory_items=10)
        from src.models import EquationFit, FitStats

        for i in range(100):
            eq = EquationFit(
                family="linear", parameters={"a": float(i)}, sympy_expr=f"{i}*x",
                stats=FitStats(r2_adj=0.9, holdout_mape=5.0, aic=100.0,
                              residual_random=True, n_obs=30),
            )
            cache.set_equation(f"hash{i}", "general", eq)

        assert len(cache._fallback) <= 10


