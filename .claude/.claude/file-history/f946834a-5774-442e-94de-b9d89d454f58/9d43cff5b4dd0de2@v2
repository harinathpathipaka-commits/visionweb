# ── Rate Limiting ─────────────────────────────────────────────────────────

class TestRateLimiter:
    def test_token_bucket_allows_up_to_limit(self):
        bucket = TokenBucket(max_tokens=10, window_sec=60)
        for _ in range(10):
            assert bucket.consume("client-a") is True

    def test_token_bucket_denies_after_exhaustion(self):
        bucket = TokenBucket(max_tokens=5, window_sec=60)
        for _ in range(5):
            bucket.consume("client-b")
        assert bucket.consume("client-b") is False

    def test_token_bucket_refills_over_time(self):
        bucket = TokenBucket(max_tokens=5, window_sec=60)
        for _ in range(5):
            bucket.consume("client-c")
        assert bucket.consume("client-c") is False
        # Artificially refill by waiting — we just verify internal state
        remaining = bucket.remaining("client-c")
        assert remaining < 1.0

    def test_token_bucket_independent_clients(self):
        bucket = TokenBucket(max_tokens=3, window_sec=60)
        for _ in range(3):
            bucket.consume("client-d")
        assert bucket.consume("client-e") is True

    def test_token_bucket_cleanup_stale_entries(self):
        bucket = TokenBucket(max_tokens=5, window_sec=1)
        for i in range(100):
            bucket.consume(f"stale-{i}")
        # After many entries, old ones should be cleaned
        bucket.consume("new-client")
        assert len(bucket._buckets) < 500  # shouldn't grow unbounded

    def test_token_bucket_thread_safety(self):
        bucket = TokenBucket(max_tokens=1000, window_sec=60)
        results = []

        def hammer(client_id):
            for _ in range(100):
                results.append(bucket.consume(client_id))

        threads = [threading.Thread(target=hammer, args=(f"t-{i}",)) for i in range(10)]
        for t in threads:
            t.start()
        for t in threads:
            t.join()
        # All operations should complete without error
        assert len(results) == 1000


# ── Cache Resilience ──────────────────────────────────────────────────────

class TestCacheFallback:
    def test_lru_fallback_stores_and_retrieves(self):
        cache = ValkeyCache(url="redis://nonexistent:9999", ttl=60)
        assert cache.available is False

        from src.models import EquationFit, FitStats
        eq = EquationFit(
            family="linear",
            parameters={"a": 2.0, "b": 1.0},
            sympy_expr="2*x + 1",
            stats=FitStats(r2_adj=0.95, holdout_mape=5.0, aic=100.0,
                          residual_random=True, n_obs=50),
        )
        cache.set_equation("hash123", "general", eq)
        result = cache.get_equation("hash123", "general")
        assert result is not None
        assert result.family == "linear"
        assert result.parameters == {"a": 2.0, "b": 1.0}

    def test_lru_evicts_oldest_when_full(self):
        cache = ValkeyCache(url="redis://nonexistent:9999", ttl=60, max_memory_items=3)

        from src.models import EquationFit, FitStats

        for i in range(5):
            eq = EquationFit(
                family="linear",
                parameters={"a": float(i)},
                sympy_expr=f"{i}*x",
                stats=FitStats(r2_adj=0.9, holdout_mape=5.0, aic=100.0,
                              residual_random=True, n_obs=30),
            )
            cache.set_equation(f"hash{i}", "general", eq)

        assert len(cache._fallback) <= 3

    def test_ttl_expiry_returns_none(self):
        cache = ValkeyCache(url="redis://nonexistent:9999", ttl=1)

        from src.models import EquationFit, FitStats
        eq = EquationFit(
            family="linear", parameters={"a": 1.0}, sympy_expr="x",
            stats=FitStats(r2_adj=0.9, holdout_mape=5.0, aic=100.0,
                          residual_random=True, n_obs=30),
        )
        cache.set_equation("expiry_test", "general", eq)
        # Force expiry
        cache._fallback["el:equation:general:expiry_test"]["expires_at"] = time.time() - 10
        result = cache.get_equation("expiry_test", "general")
        assert result is None

    def test_invalidate_removes_from_lru(self):
        cache = ValkeyCache(url="redis://nonexistent:9999", ttl=60)

        from src.models import EquationFit, FitStats
        eq = EquationFit(
            family="linear", parameters={"a": 1.0}, sympy_expr="x",
            stats=FitStats(r2_adj=0.9, holdout_mape=5.0, aic=100.0,
                          residual_random=True, n_obs=30),
        )
        cache.set_equation("inv_test", "general", eq)
        assert cache.get_equation("inv_test", "general") is not None
        cache.invalidate("inv_test", "general")
        assert cache.get_equation("inv_test", "general") is None

    def test_corrupt_cache_data_returns_none(self):
        cache = ValkeyCache(url="redis://nonexistent:9999", ttl=60)
        cache._fallback["el:equation:general:corrupt"] = {
            "value": {"family": "linear"},  # missing stats
            "expires_at": time.time() + 3600,
        }
        result = cache.get_equation("corrupt", "general")
        assert result is None


# ── Queue Resilience ───────────────────────────────────────────────────────

class TestQueueFallback:
    def test_fallback_queue_enqueues_and_dequeues(self):
        queue = ValkeyQueue(url="redis://nonexistent:9999")
        assert queue.available is False

        queue.enqueue_refit(42)
        queue.enqueue_ingestion(7)

        job1 = queue.dequeue("worker-1", timeout=1)
        job2 = queue.dequeue("worker-1", timeout=1)

        assert job1 == {"type": "refit", "equation_id": 42}
        assert job2 == {"type": "ingestion", "file_id": 7}

    def test_fallback_queue_returns_none_when_empty(self):
        queue = ValkeyQueue(url="redis://nonexistent:9999")
        assert queue.dequeue("worker-1", timeout=1) is None

    def test_queue_length_reports_correctly(self):
        queue = ValkeyQueue(url="redis://nonexistent:9999")
        assert queue.queue_length("refit") == 0
        queue.enqueue_refit(1)
        queue.enqueue_refit(2)
        assert queue.queue_length("refit") == 2
        queue.dequeue("w1")
        assert queue.queue_length("refit") == 1


# ── Database Resilience ───────────────────────────────────────────────────

class TestDatabaseResilience:
    def test_connection_is_thread_local(self):
        conn1 = get_connection()
        conn2 = get_connection()
        assert conn1 is conn2  # same thread, same connection

    def test_transaction_commits_on_success(self):
        db_path = str(Path(tempfile.gettempdir()) / f"test_commit_{os.getpid()}.db")
        try:
            with transaction(db_path) as conn:
                conn.execute("CREATE TABLE test_tbl (id INTEGER PRIMARY KEY, val TEXT)")
                conn.execute("INSERT INTO test_tbl VALUES (1, 'hello')")
            with transaction(db_path, readonly=True) as conn:
                row = conn.execute("SELECT val FROM test_tbl WHERE id=1").fetchone()
                assert row["val"] == "hello"
        finally:
            try:
                os.unlink(db_path)
            except PermissionError:
                pass

    def test_transaction_rolls_back_on_error(self):
        db_path = str(Path(tempfile.gettempdir()) / f"test_rollback_{os.getpid()}.db")
        try:
            with transaction(db_path) as conn:
                conn.execute("CREATE TABLE test_tbl (id INTEGER PRIMARY KEY, val TEXT)")
                conn.execute("INSERT INTO test_tbl VALUES (1, 'keep_me')")

            with pytest.raises((sqlite3.OperationalError, sqlite3.IntegrityError)):
                with transaction(db_path) as conn:
                    conn.execute("INSERT INTO test_tbl VALUES (1, 'collision')")  # PK violation
                    conn.execute("INSERT INTO test_tbl VALUES (2, 'should_not_exist')")
        finally:
            try:
                os.unlink(db_path)
            except PermissionError:
                pass

    def test_retry_on_locked_db(self):
        conn_count = [0]

        def mock_connect(path):
            conn_count[0] += 1
            raise sqlite3.OperationalError("database is locked")

        with patch("src.db.sqlite3.connect", mock_connect):
            with pytest.raises(sqlite3.OperationalError, match="locked"):
                with transaction("/fake/path.db") as conn:
                    pass

        # Should have retried MAX_RETRIES times
        assert conn_count[0] == MAX_RETRIES

    def test_readonly_transaction_prevents_writes(self):
        db_path = str(Path(tempfile.gettempdir()) / f"test_readonly_{os.getpid()}.db")
        try:
            with transaction(db_path) as conn:
                conn.execute("CREATE TABLE test_tbl (id INTEGER PRIMARY KEY, val TEXT)")
            with transaction(db_path, readonly=True) as conn:
                with pytest.raises(sqlite3.OperationalError):
                    conn.execute("INSERT INTO test_tbl VALUES (1, 'nope')")
        finally:
            try:
                os.unlink(db_path)
            except PermissionError:
                pass

    def test_exponential_backoff_increases_delay(self):
        delays = [RETRY_DELAY * (2**i) for i in range(MAX_RETRIES - 1)]
        for i in range(len(delays) - 1):
            assert delays[i + 1] >= delays[i]  # backoff never decreases


