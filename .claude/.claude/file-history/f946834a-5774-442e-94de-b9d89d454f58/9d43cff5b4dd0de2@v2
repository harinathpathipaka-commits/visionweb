class TestSystemEdgeCases:
    def test_very_long_query_truncated(self, client):
        x, y = _make_x_y(20)
        long_query = "x" * 5000  # exceeds MAX_QUERY_LENGTH=4000
        response = client.post(
            "/v1/solve",
            json={"query": long_query, "x_values": x, "y_values": y},
        )
        # Should be rejected by Pydantic validation
        assert response.status_code == 422

    def test_empty_query_rejected(self, client):
        x, y = _make_x_y(20)
        response = client.post(
            "/v1/solve",
            json={"query": "", "x_values": x, "y_values": y},
        )
        assert response.status_code == 422

    def test_missing_required_fields(self, client):
        response = client.post("/v1/solve", json={})
        assert response.status_code == 422

    def test_response_has_content_type_json(self, client):
        x, y = _make_x_y(20)
        response = client.post(
            "/v1/solve",
            json={"query": "relation?", "x_values": x, "y_values": y},
        )
        assert "application/json" in response.headers["content-type"]

    def test_api_handles_null_bytes_in_query(self, client):
        x, y = _make_x_y(20)
        response = client.post(
            "/v1/solve",
            json={"query": "test" + chr(0) + "query", "x_values": x, "y_values": y},
        )
        # Either reject cleanly or handle gracefully; must not 500
        assert response.status_code != 500


