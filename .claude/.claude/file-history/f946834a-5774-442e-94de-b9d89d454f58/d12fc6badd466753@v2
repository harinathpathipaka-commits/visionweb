class TestStructuralValidity:
    """Verify structural validity checks make domain-appropriate decisions."""

    def test_linear_always_valid(self):
        assert structural_validity({"a": 2.0, "b": 1.0}, "linear", "general") is True
        assert structural_validity({"a": -2.0, "b": 1.0}, "linear", "finance.saas.smb") is True

    def test_power_negative_a_invalid(self):
        """Power law with negative coefficient violates domain constraints."""
        assert structural_validity({"a": -1.0, "b": 2.0}, "power", "general") is False

    def test_power_positive_b_in_finance_invalid(self):
        """Power law with positive exponent in finance may indicate overfitting."""
        assert structural_validity({"a": 1.0, "b": 0.5}, "power", "finance.saas.smb") is False

    def test_logistic_negative_l_invalid(self):
        """Logistic with negative carrying capacity is invalid."""
        assert structural_validity({"L": -10.0, "k": 0.5, "x0": 0.0}, "logistic", "general") is False

    def test_exponential_positive_b_in_saas_invalid(self):
        """Exponential growth in SaaS is usually a sign of data issues."""
        assert structural_validity({"a": 1.0, "b": 0.5}, "exponential", "finance.saas.smb") is False


