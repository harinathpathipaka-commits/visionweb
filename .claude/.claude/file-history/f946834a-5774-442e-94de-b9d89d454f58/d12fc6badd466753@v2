class TestConfidenceIntervalCoverage:
    """Verify that CI intervals are statistically meaningful."""

    def test_ci_bounds_are_ordered(self):
        """CI lower bound must be <= upper bound."""
        from src.probabilistic import laplace_approximation
        eq = EquationFit(
            family="linear", parameters={"a": 2.0, "b": 1.0},
            sympy_expr="2*x + 1",
            stats=FitStats(r2_adj=0.95, holdout_mape=0.05, aic=100.0,
                          residual_random=True, n_obs=20),
        )
        prob = laplace_approximation(eq, x_value=5.0, n_samples=2000)
        assert prob.ci_95[0] <= prob.ci_95[1], \
            f"CI lower {prob.ci_95[0]} > upper {prob.ci_95[1]}"
        assert prob.std >= 0, "Standard deviation must be non-negative"

    def test_mean_near_evaluation_point(self):
        """The probabilistic mean should be near the expected value at x_value."""
        from src.probabilistic import laplace_approximation
        eq = EquationFit(
            family="linear", parameters={"a": 2.0, "b": 1.0},
            sympy_expr="2*x + 1",
            stats=FitStats(r2_adj=0.99, holdout_mape=0.01, aic=80.0,
                          residual_random=True, n_obs=50),
        )
        prob = laplace_approximation(eq, x_value=10.0, n_samples=2000)
        expected = 2.0 * 10.0 + 1.0  # = 21.0
        # Mean should be within a few std of expected
        assert abs(prob.mean - expected) < 3.0 * max(prob.std, 0.01), \
            f"Mean {prob.mean} far from expected {expected}, std={prob.std}"


