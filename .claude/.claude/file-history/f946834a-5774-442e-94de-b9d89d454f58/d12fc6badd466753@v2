# Gate correctness
# ═══════════════════════════════════════════════════════════════════════════════

class TestGateCorrectness:
    """Verify the quality gate makes correct pass/fail decisions."""

    def test_good_fit_passes(self):
        stats = FitStats(r2_adj=0.85, holdout_mape=0.05, aic=100.0,
                        residual_random=True, n_obs=30)
        assert gate(stats).passed is True

    def test_low_r2_fails(self):
        stats = FitStats(r2_adj=0.3, holdout_mape=0.05, aic=100.0,
                        residual_random=True, n_obs=30)
        result = gate(stats)
        assert result.passed is False
        assert "r2" in result.reason.lower()

    def test_too_few_observations_fails(self):
        stats = FitStats(r2_adj=0.85, holdout_mape=0.05, aic=100.0,
                        residual_random=True, n_obs=5)
        result = gate(stats)
        assert result.passed is False
        assert "observation" in result.reason.lower()

    def test_high_mape_fails(self):
        stats = FitStats(r2_adj=0.85, holdout_mape=50.0, aic=100.0,
                        residual_random=True, n_obs=30)
        result = gate(stats)
        assert result.passed is False
        assert "mape" in result.reason.lower()

    def test_non_random_residuals_fails(self):
        stats = FitStats(r2_adj=0.85, holdout_mape=0.05, aic=100.0,
                        residual_random=False, n_obs=30)
        result = gate(stats)
        assert result.passed is False

    def test_correlated_data_passes_gate(self):
        """Realistic correlated data should pass the gate."""
        rng = np.random.default_rng(42)
        x = [float(i) for i in range(25)]
        y = [3.0 * xi + 5.0 + rng.normal(0, 2.0) for xi in x]
        candidates = fit_canonical_families(x, y)
        best = choose_best(candidates)
        if best is not None:
            result = gate(best.stats)
            # May pass or fail depending on random noise — either is fine
            assert result.reason is not None or result.passed is True


