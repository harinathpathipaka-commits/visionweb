# Correlation analysis correctness
# ═══════════════════════════════════════════════════════════════════════════════

class TestCorrelationCorrectness:
    """Verify correlation analysis produces correct results."""

    def test_perfect_linear_correlation(self):
        x = [float(i) for i in range(20)]
        y = [2.0 * xi + 1.0 for xi in x]
        rho = correlation_matrix(x, y)
        assert abs(rho[("x", "y")] - 1.0) < 0.01

    def test_perfect_negative_correlation(self):
        x = [float(i) for i in range(20)]
        y = [-2.0 * xi + 100.0 for xi in x]
        rho = correlation_matrix(x, y)
        assert abs(rho[("x", "y")] - (-1.0)) < 0.01

    def test_no_correlation(self):
        rng = np.random.default_rng(12345)
        x = [float(i) for i in range(50)]
        y = rng.normal(0, 1, 50).tolist()
        rho = correlation_matrix(x, y)
        # With 50 random points, correlation should be low (|r| < 0.3)
        assert abs(rho[("x", "y")]) < 0.5, \
            f"Expected low correlation, got {rho[('x', 'y')]}"

    def test_too_few_points_returns_empty(self):
        rho = correlation_matrix([1.0], [2.0])
        assert rho == {} or rho[("x", "y")] is not None


