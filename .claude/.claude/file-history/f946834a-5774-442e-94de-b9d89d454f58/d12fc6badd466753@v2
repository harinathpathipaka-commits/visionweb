class TestHoldoutMAPE:
    """Verify holdout MAPE correctly estimates prediction error."""

    def test_mape_zero_for_perfect_prediction(self):
        """Perfect prediction gives zero holdout MAPE."""
        from src.fitting import _compute_holdout_mape
        fn = lambda params, x: params[0] * x + params[1]
        x_hold = np.array([6.0, 7.0])
        y_hold = np.array([13.0, 15.0])  # perfect y=2x+1
        mape = _compute_holdout_mape(fn, (2.0, 1.0), x_hold, y_hold)
        assert mape < 0.01

    def test_mape_nonzero_for_bad_prediction(self):
        """Poor prediction gives nonzero holdout MAPE."""
        from src.fitting import _compute_holdout_mape
        fn = lambda params, x: params[0] * x + params[1]
        x_hold = np.array([6.0, 7.0])
        y_hold = np.array([13.0, 15.0])
        mape = _compute_holdout_mape(fn, (0.5, 0.0), x_hold, y_hold)
        assert mape > 0.5  # bad prediction — MAPE > 50%

    def test_mape_handles_zero_y(self):
        """MAPE should handle y_hold values near zero gracefully."""
        from src.fitting import _compute_holdout_mape
        fn = lambda params, x: params[0] + x * 0
        x_hold = np.array([1.0, 2.0])
        y_hold = np.array([0.0, 0.01])
        mape = _compute_holdout_mape(fn, (1.0,), x_hold, y_hold)
        # Should not be NaN or Inf
        assert not math.isnan(mape)
        assert not math.isinf(mape)


