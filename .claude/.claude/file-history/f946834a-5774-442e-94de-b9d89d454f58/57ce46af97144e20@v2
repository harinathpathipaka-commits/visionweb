class TestPrometheusInjection:
    def test_prometheus_endpoint_not_exploitable(self, client):
        """Prometheus metrics endpoint should not be exploitable via query params."""
        response = client.get("/metrics?query=up&time=123")
        assert response.status_code == 200
        # Must return text/plain (Prometheus format), not HTML
        assert "text/plain" in response.headers.get("content-type", "")

    def test_metrics_no_xss(self, client):
        """Metrics endpoint should not reflect query params."""
        response = client.get("/metrics?q=<script>alert(1)</script>")
        assert response.status_code == 200
        text = response.text
        # Should not contain the script tag in output
        assert "<script>" not in text.lower()
