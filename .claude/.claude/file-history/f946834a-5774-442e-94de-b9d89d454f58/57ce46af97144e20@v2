class TestSolveInjectionAttacks:
    def test_sql_injection_in_query(self, client):
        """SQL injection in query string should not cause DB corruption or crash."""
        x = [float(i) for i in range(20)]
        y = [float(i * 2) for i in range(20)]
        payloads = [
            "'; DROP TABLE equation_library; --",
            "1; DELETE FROM observation_ledger WHERE 1=1; --",
            "' OR '1'='1",
            "1' UNION SELECT * FROM equation_library --",
            "x'; INSERT INTO equation_library DEFAULT VALUES; --",
        ]
        for payload in payloads:
            response = client.post("/v1/solve", json={
                "query": payload,
                "x_values": x,
                "y_values": y,
            })
            # Must not crash (query goes through NLP parser, not SQL)
            assert response.status_code != 500, \
                f"SQL injection '{payload[:40]}' caused 500: {response.text}"

    def test_xss_in_query(self, client):
        """XSS payloads in query should be harmless."""
        x = [float(i) for i in range(20)]
        y = [float(i * 2) for i in range(20)]
        payloads = [
            "<script>alert('xss')</script>",
            "<img src=x onerror=alert(1)>",
            "javascript:alert(1)",
        ]
        for payload in payloads:
            response = client.post("/v1/solve", json={
                "query": payload,
                "x_values": x,
                "y_values": y,
            })
            assert response.status_code != 500, \
                f"XSS payload '{payload[:40]}' caused 500: {response.text}"

    def test_unicode_bomb_in_query(self, client):
        """Unicode-heavy query should not crash."""
        x = [float(i) for i in range(20)]
        y = [float(i * 2) for i in range(20)]
        response = client.post("/v1/solve", json={
            "query": "关系 " + chr(0) + " ￿ \U0001f4a9 " + ("x" * 50),
            "x_values": x,
            "y_values": y,
        })
        assert response.status_code != 500, f"Unicode payload caused 500: {response.text}"

    def test_newlines_and_control_chars_in_query(self, client):
        """Control characters in query should not crash."""
        x = [float(i) for i in range(20)]
        y = [float(i * 2) for i in range(20)]
        ctrl = "test\n\r\t" + chr(27) + chr(7) + " query"
        response = client.post("/v1/solve", json={
            "query": ctrl,
            "x_values": x,
            "y_values": y,
        })
        assert response.status_code != 500, \
            f"Control chars caused 500: {response.status_code}"


