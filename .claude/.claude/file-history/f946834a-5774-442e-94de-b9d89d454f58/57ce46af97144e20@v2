class TestEdgeCaseDataShapes:
    def test_all_zeros_y(self, client):
        """All zero y-values (makes MAPE undefined via division by zero)."""
        x = [float(i) for i in range(20)]
        y = [0.0] * 20
        response = client.post("/v1/solve", json={
            "query": "test",
            "x_values": x,
            "y_values": y,
        })
        # Gate may fail but should not 500 crash
        assert response.status_code != 500, \
            f"All-zero y caused 500: {response.text}"

    def test_all_zeros_x(self, client):
        """All zero x-values (log/power models need x > 0)."""
        x = [0.0] * 20
        y = [float(i) for i in range(20)]
        response = client.post("/v1/solve", json={
            "query": "test",
            "x_values": x,
            "y_values": y,
        })
        assert response.status_code != 500, \
            f"All-zero x caused 500: {response.text}"

    def test_constant_y_values(self, client):
        """Constant y makes R² undefined (zero variance)."""
        x = [float(i) for i in range(20)]
        y = [5.0] * 20
        response = client.post("/v1/solve", json={
            "query": "test",
            "x_values": x,
            "y_values": y,
        })
        assert response.status_code != 500, \
            f"Constant y caused 500: {response.text}"

    def test_alternating_signs(self, client):
        """Widely alternating positive/negative values."""
        x = [float(i) for i in range(20)]
        y = [(-1)**i * (i * 1000) for i in range(20)]
        response = client.post("/v1/solve", json={
            "query": "test relationship",
            "x_values": x,
            "y_values": y,
        })
        assert response.status_code != 500, \
            f"Alternating signs caused 500: {response.text}"

    def test_exponential_growth_overflow_risk(self, client):
        """Rapid exponential growth may overflow during fitting."""
        x = [float(i) for i in range(20)]
        y = [2.0**i for i in range(20)]  # up to 2^19 = 524,288 — manageable
        response = client.post("/v1/solve", json={
            "query": "growth?",
            "x_values": x,
            "y_values": y,
        })
        assert response.status_code != 500, \
            f"Exponential data caused 500: {response.text}"


