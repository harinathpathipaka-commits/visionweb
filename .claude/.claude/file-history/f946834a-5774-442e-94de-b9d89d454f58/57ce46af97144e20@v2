class TestIngestFileAttacks:
    def test_no_file_provided(self, client):
        """Missing file should get 400."""
        response = client.post("/v1/ingest")
        assert response.status_code == 422, \
            f"Expected 422 for missing file, got {response.status_code}"

    def test_empty_filename(self, client):
        """Empty filename should be rejected."""
        response = client.post(
            "/v1/ingest",
            files={"file": ("", b"content", "text/csv")},
        )
        assert response.status_code == 400, \
            f"Expected 400 for empty filename, got {response.status_code}"

    def test_wrong_content_type(self, client):
        """Non-CSV content types should get 415."""
        response = client.post(
            "/v1/ingest",
            files={"file": ("test.png", b"\x89PNG\r\n\x1a\n", "image/png")},
        )
        assert response.status_code == 415, \
            f"Expected 415 for PNG, got {response.status_code}"

    def test_binary_data_as_csv(self, client):
        """Raw binary data uploaded as CSV should not crash."""
        binary_blob = bytes([0, 1, 2, 3, 255, 254, 253])
        response = client.post(
            "/v1/ingest",
            files={"file": ("test.csv", binary_blob, "text/csv")},
        )
        # Should not 500 — may succeed (bad data) or get 4xx
        assert response.status_code != 500, \
            f"Binary data caused 500 crash: {response.text}"

    def test_file_exceeds_size_limit(self, client):
        """File larger than MAX_UPLOAD_BYTES should get 413."""
        big_data = b"a,b\n" + b"1,2\n" * (55_000_000 // 4)
        response = client.post(
            "/v1/ingest",
            files={"file": ("big.csv", big_data, "text/csv")},
        )
        assert response.status_code == 413, \
            f"Expected 413 for oversized file, got {response.status_code}"

    def test_zero_byte_file(self, client):
        """Zero-byte file should be handled gracefully."""
        response = client.post(
            "/v1/ingest",
            files={"file": ("empty.csv", b"", "text/csv")},
        )
        assert response.status_code != 500, \
            f"Zero-byte file caused 500 crash: {response.text}"

    def test_bom_encoded_csv(self, client):
        """UTF-8 BOM in CSV header should be handled."""
        content = b"\xef\xbb\xbfdate,value\n2024-01-01,100\n"
        response = client.post(
            "/v1/ingest",
            files={"file": ("bom.csv", content, "text/csv")},
        )
        assert response.status_code != 500, \
            f"BOM CSV caused 500 crash: {response.text}"

    def test_csv_with_only_headers(self, client):
        """CSV with headers but no data rows should not crash."""
        response = client.post(
            "/v1/ingest",
            files={"file": ("headers.csv", b"col1,col2,col3\n", "text/csv")},
        )
        assert response.status_code != 500, \
            f"Headers-only CSV caused 500 crash: {response.text}"


