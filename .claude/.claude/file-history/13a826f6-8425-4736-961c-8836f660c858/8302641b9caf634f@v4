//! Heuristic rules for distraction classification and injection detection.
//!
//! Rules are loaded from embedded defaults at startup. Hot-reload from
//! `~/.ans/rules/` is deferred to a future phase.

use regex::Regex;

/// A single heuristic rule for classification or detection.
#[derive(Debug, Clone)]
pub struct Rule {
    pub name: String,
    pub pattern: Regex,
    pub kind: String,
    pub action: String,
    pub confidence: f32,
}

// ── Built-in Distraction Rules ─────────────────────────────────────────

/// Default distraction classification rules — URL patterns.
pub fn url_rules() -> Vec<Rule> {
    vec![
        rule(
            "ad_doubleclick",
            r"(?i)doubleclick\.net|googlesyndication\.com",
            "ad",
            "block",
            0.95,
        ),
        rule(
            "ad_tracking_params",
            r"(?i)[?&](utm_source|utm_medium|utm_campaign|fbclid|gclid)=",
            "ad",
            "ignore",
            0.3,
        ),
        rule(
            "redirect_tracking",
            r"(?i)redirect|r\.php\?|out\.php\?",
            "redirect",
            "navigate_back",
            0.7,
        ),
        rule(
            "popup_url",
            r"(?i)popup|popunder|pop-up",
            "popup",
            "dismiss",
            0.8,
        ),
    ]
}

