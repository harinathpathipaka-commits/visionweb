/**
 * LayerInfinite MCP Server — gateway-proxy.ts
 * ══════════════════════════════════════════════════════════════
 * Core V2 Gateway Proxy. Intercepts tools/list (pre-reasoning
 * enrichment) and tools/call (proxy to upstream + auto-mode
 * rerouting). Natural language enrichment per mode — never
 * bracketed metadata.
 * ══════════════════════════════════════════════════════════════
 */

import type { GatewayConfig } from './config.js';
import type {
  EnrichedTool,
  EnrichmentContext,
  ScoredAction,
  PolicyDecision,
  DecisionRecord,
  OutcomePayload,
  GatewayMode,
} from './types.js';
import type { LiApiClient, UpstreamMCPClient, RawUpstreamTool, UpstreamCallResult } from './rest-client.js';
import type { UpstreamRegistry } from './upstream-registry.js';
import { enqueueOutcome } from './fail-open.js';
import { logger } from './logger.js';

const log = logger.forTool('gateway-proxy');

// ── Base62 alphabet ─────────────────────────────────────────

const BASE62 = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';

// ── Auto-mode reroute threshold ─────────────────────────────

const REROUTE_CONFIDENCE_THRESHOLD = 0.3;

// ══════════════════════════════════════════════════════════════
// generateDecisionId
// ══════════════════════════════════════════════════════════════

function base62Encode(n: number, minLen: number): string {
  let s = '';
  let v = n;
  while (v > 0) {
    s = BASE62[v % 62] + s;
    v = Math.floor(v / 62);
  }
  return s.padStart(minLen, '0');
}

function djb2(s: string): number {
  let hash = 5381;
  for (let i = 0; i < s.length; i++) {
    hash = ((hash << 5) + hash) + s.charCodeAt(i);
    hash = hash >>> 0; // Force unsigned 32-bit
  }
  return hash;
}

function randomBase62(len: number): string {
  let s = '';
  for (let i = 0; i < len; i++) {
    s += BASE62[Math.floor(Math.random() * 62)];
  }
  return s;
}

export function generateDecisionId(agentId: string): string {
  const ts12 = base62Encode(Date.now(), 12);
  const agent4 = base62Encode(djb2(agentId), 4).slice(0, 4);
  const rand4 = randomBase62(4);
  return `dec_${ts12}_${agent4}_${rand4}`;
}

// ══════════════════════════════════════════════════════════════
// GatewayProxy
// ══════════════════════════════════════════════════════════════

export class GatewayProxy {
  constructor(
    private readonly liApi: LiApiClient,
    private readonly upstreamClient: UpstreamMCPClient,
    private readonly registry: UpstreamRegistry,
    private readonly config: GatewayConfig,
  ) {}

  // ── tools/list handler ───────────────────────────────────

  async handleListTools(taskContext: {
    taskType: string;
    customerId: string;
    agentId: string;
  }): Promise<EnrichedTool[]> {
    const mode = this.effectiveMode(taskContext.taskType);

    try {
      const [rawTools, context] = await Promise.all([
        this.upstreamClient.listTools(),
        this.getEnrichmentContext(taskContext.taskType, taskContext.customerId, taskContext.agentId, mode),
      ]);

      const enriched = await this.enrichTools(rawTools, context);

      // Inject virtual li_recommend tool (only in non-bootstrap modes)
      if (mode !== 'bootstrap') {
        enriched.push(this.liRecommendTool());
      }

      // Sort: ranked first, then alphabetically
      enriched.sort((a, b) => {
        const rankA = a.annotations?.ranking ?? 999;
        const rankB = b.annotations?.ranking ?? 999;
        if (rankA !== rankB) return rankA - rankB;
        return a.name.localeCompare(b.name);
      });

      log.debug('tools/list enriched', {
        count: enriched.length,
        mode,
        taskType: taskContext.taskType,
      });

      return enriched;
    } catch (err) {
      log.error('tools/list failed', { error: err instanceof Error ? err.message : String(err) });
      // Degrade: return raw tools with no enrichment
      try {
        const rawTools = await this.upstreamClient.listTools();
        return rawTools.map((t) => ({
          name: t.name,
          description: t.description,
          inputSchema: t.inputSchema,
          upstreamName: t.upstreamName,
        }));
      } catch {
        return [];
      }
    }
  }

  // ── tools/call handler ───────────────────────────────────

  async handleCallTool(
    toolName: string,
    args: Record<string, unknown>,
    taskContext: { taskType: string; customerId: string; agentId: string },
  ): Promise<UpstreamCallResult> {
    const decisionId = generateDecisionId(taskContext.agentId);
    const mode = this.effectiveMode(taskContext.taskType);
    const startMs = Date.now();

    // Handle virtual li_recommend tool
    if (toolName === 'li_recommend') {
      try {
        const scores = await this.liApi.getScores(
          taskContext.taskType,
          taskContext.customerId,
          taskContext.agentId,
        );
        const text = this.formatRecommendations(scores);
        return { content: [{ type: 'text', text }] };
      } catch (err) {
        return {
          content: [{ type: 'text', text: 'Unable to fetch recommendations right now. Please try again or select a tool manually.' }],
          isError: true,
        };
      }
    }

    // Determine which tool to execute (auto-mode may reroute)
    let executedAction = toolName;
    let originalAction = toolName;
    let rerouted = false;
    let enrichmentScores: Record<string, number> = {};

    if (mode === 'auto' && !this.config.shadowMode) {
      try {
        const [scores, policy] = await Promise.all([
          this.liApi.getScores(taskContext.taskType, taskContext.customerId, taskContext.agentId),
          this.liApi.getPolicyDecision(taskContext.taskType, taskContext.customerId, taskContext.agentId),
        ]);

        for (const s of scores) {
          enrichmentScores[s.actionName] = s.compositeScore;
        }

        if (
          policy &&
          policy.confidence >= REROUTE_CONFIDENCE_THRESHOLD &&
          policy.action !== toolName &&
          this.registry.isHealthy(this.resolveUpstream(policy.action))
        ) {
          originalAction = toolName;
          executedAction = policy.action;
          rerouted = true;
          log.info('Auto-mode reroute', {
            decisionId,
            from: toolName,
            to: policy.action,
            confidence: policy.confidence,
            reason: policy.reason,
          });
        }
      } catch {
        // Degrade — continue with original tool
      }
    }

    // Resolve upstream from tool name
    const upstreamName = this.resolveUpstream(executedAction);

    // Proxy to upstream
    const result = await this.upstreamClient.callTool(upstreamName, executedAction, args);

    // Fire-and-forget outcome logging
    const latencyMs = Date.now() - startMs;
    void this.logDecision({
      decisionId,
      agentId: taskContext.agentId,
      customerId: taskContext.customerId,
      taskType: taskContext.taskType,
      actionName: executedAction,
      upstreamName,
      originalAction,
      executedAction,
      mode,
      rerouted,
      enrichmentScores,
      latencyMs,
    });

    return result;
  }

  // ── Shutdown ─────────────────────────────────────────────

  async shutdown(): Promise<void> {
    this.registry.stopHealthChecks();
    log.info('Gateway proxy shut down');
  }

  // ── Private: enrichment ──────────────────────────────────

  private async enrichTools(
    tools: RawUpstreamTool[],
    context: EnrichmentContext,
  ): Promise<EnrichedTool[]> {
    const { mode, scores } = context;

    // Build score lookup
    const scoreMap = new Map<string, ScoredAction>();
    for (const s of scores) {
      scoreMap.set(s.actionName, s);
    }

    // Sort scores by composite score desc for ranking
    const ranked = [...scores].sort((a, b) => b.compositeScore - a.compositeScore);

    return tools.map((tool) => {
      const score = scoreMap.get(tool.name);
      const rank = score ? ranked.findIndex((s) => s.actionName === tool.name) + 1 : undefined;
      const enrichedDesc =
        mode === 'bootstrap'
          ? tool.description
          : this.enrichDescription(tool, score ?? null, rank ?? null, mode, context.taskType);

      return {
        name: tool.name,
        description: enrichedDesc,
        inputSchema: tool.inputSchema,
        upstreamName: tool.upstreamName,
        annotations: {
          ranking: rank ?? undefined,
          category: this.categorize(score ?? null),
        },
      };
    });
  }

  private enrichDescription(
    tool: RawUpstreamTool,
    score: ScoredAction | null,
    rank: number | null,
    mode: GatewayMode,
    taskType: string,
  ): string {
    const base = tool.description;

    if (!score || score.sampleSize < 1) {
      if (mode === 'assist' || mode === 'auto') {
        return `${base}\n\nNo historical data available for this tool on "${taskType}" tasks. Consider testing it in a low-risk context first.`;
      }
      return base;
    }

    const trendText = this.trendLabel(score.trendLabel);
    const rankText = rank ? `This is the #${rank} recommended tool for this task.` : '';

    switch (mode) {
      case 'recommend':
        return `${base}\n\nHistorically for "${taskType}" tasks, ${tool.name} has a ${score.successRate}% success rate across ${score.sampleSize} executions. ${rankText}`.trim();

      case 'assist':
      case 'auto':
        return `${base}\n\nHistorically for "${taskType}" tasks, ${tool.name} has a ${score.successRate}% success rate across ${score.sampleSize} executions${trendText}. ${rankText} ⚠ Consider the success history when choosing tools.`.trim();

      default:
        return base;
    }
  }

  private trendLabel(trendLabel?: string): string {
    if (!trendLabel) return '';
    switch (trendLabel) {
      case 'strongly_improving': return ' and has been improving significantly';
      case 'improving': return ' and has been improving';
      case 'slightly_improving': return ' with a slight positive trend';
      case 'stable': return '';
      case 'slightly_declining': return ' with a slight negative trend';
      case 'declining': return ' but has been declining';
      case 'sharply_declining': return ' but has been declining significantly';
      default: return '';
    }
  }

  private categorize(score: ScoredAction | null): 'recommended' | 'neutral' | 'warning' | undefined {
    if (!score || score.sampleSize < 3) return undefined;
    if (score.compositeScore >= 0.7) return 'recommended';
    if (score.compositeScore >= 0.4) return 'neutral';
    return 'warning';
  }

  // ── Private: context ─────────────────────────────────────

  private async getEnrichmentContext(
    taskType: string,
    customerId: string,
    agentId: string,
    mode: GatewayMode,
  ): Promise<EnrichmentContext> {
    // Bootstrap mode — no enrichment needed
    if (mode === 'bootstrap') {
      return {
        taskType,
        customerId,
        agentId,
        mode,
        scores: [],
        policyDecision: null,
      };
    }

    try {
      const [scores, policyDecision] = await Promise.all([
        this.liApi.getScores(taskType, customerId, agentId),
        this.liApi.getPolicyDecision(taskType, customerId, agentId),
      ]);

      return { taskType, customerId, agentId, mode, scores, policyDecision };
    } catch (err) {
      log.warn('Enrichment context fetch failed — degrading to bootstrap-like', {
        error: err instanceof Error ? err.message : String(err),
      });
      return {
        taskType,
        customerId,
        agentId,
        mode,
        scores: [],
        policyDecision: null,
      };
    }
  }

  // ── Private: li_recommend virtual tool ───────────────────

  private liRecommendTool(): EnrichedTool {
    return {
      name: 'li_recommend',
      description:
        'Get LayerInfinite recommendations for the best tool to use for this task type based on historical success data across all agents.',
      inputSchema: {
        type: 'object',
        properties: {},
        required: [],
      },
      upstreamName: 'layerinfinite',
      annotations: { category: 'recommended', ranking: 0 },
    };
  }

  private formatRecommendations(scores: ScoredAction[]): string {
    if (scores.length === 0) {
      return 'No recommendations available yet. Execute a few tasks to build up outcome history.';
    }

    const ranked = [...scores]
      .sort((a, b) => b.compositeScore - a.compositeScore)
      .slice(0, 5);

    const lines = ['**Top recommended tools:**', ''];
    for (let i = 0; i < ranked.length; i++) {
      const s = ranked[i];
      const trendIcon =
        s.trendLabel === 'improving' || s.trendLabel === 'strongly_improving'
          ? ' ↑'
          : s.trendLabel === 'declining' || s.trendLabel === 'sharply_declining'
            ? ' ↓'
            : '';
      lines.push(
        `${i + 1}. **${s.actionName}** — ${s.successRate}% success (${s.sampleSize} runs)${trendIcon}`,
      );
    }
    lines.push('');
    lines.push('Call a tool by name to execute it. LayerInfinite will automatically reroute in Auto mode when a better tool is available.');

    return lines.join('\n');
  }

  // ── Private: helpers ─────────────────────────────────────

  private effectiveMode(taskType: string): GatewayMode {
    if (this.config.mode === null) return 'bootstrap';
    return this.config.modeOverrides.get(taskType) ?? this.config.mode;
  }

  private resolveUpstream(toolName: string): string {
    // Check all upstreams for the tool
    const entries = this.registry.getAllUpstreams();
    for (const entry of entries) {
      if (entry.healthy) return entry.server.name;
    }
    // Fall back to first upstream
    return entries[0]?.server.name ?? 'unknown';
  }

  private async logDecision(record: {
    decisionId: string;
    agentId: string;
    customerId: string;
    taskType: string;
    actionName: string;
    upstreamName: string;
    originalAction: string;
    executedAction: string;
    mode: GatewayMode;
    rerouted: boolean;
    enrichmentScores: Record<string, number>;
    latencyMs: number;
  }): Promise<void> {
    try {
      const payload: OutcomePayload = {
        decision_id: record.decisionId,
        agent_id: record.agentId,
        customer_id: record.customerId,
        task_type: record.taskType,
        action_name: record.actionName,
        upstream_name: record.upstreamName,
        original_action: record.originalAction,
        executed_action: record.executedAction,
        mode: record.mode,
        rerouted: record.rerouted,
        latency_ms: record.latencyMs,
        timestamp: new Date().toISOString(),
        ingestion_source: 'mcp',
        environment: this.config.environment,
      };

      const sent = await this.liApi.logOutcome(payload);
      if (!sent) {
        await enqueueOutcome(payload);
      }
    } catch {
      // Fire-and-forget — silent failure is acceptable
      log.debug('Outcome logging skipped (non-critical)');
    }
  }
}
