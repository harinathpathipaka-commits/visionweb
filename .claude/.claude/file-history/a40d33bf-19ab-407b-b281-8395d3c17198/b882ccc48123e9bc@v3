  recoveryDom.textInput=document.getElementById('textInput');
  recoveryDom.resumeBtn=document.getElementById('resumeBtn');
  recoveryDom.cancelBtn=document.getElementById('cancelRecoveryBtn');
  recoveryDom.sessGoal=document.getElementById('sessGoal');
  recoveryDom.sessSubGoal=document.getElementById('sessSubGoal');
  recoveryDom.sessSteps=document.getElementById('sessSteps');
  recoveryDom.sessPaused=document.getElementById('sessPaused');
  recoveryDom.sessUrl=document.getElementById('sessUrl');
}
let recoveryWired=false;
function wireRecovery(){
  if(recoveryWired)return;
  cacheRecoveryDom();
  let vp=recoveryDom.viewport;
  // Click on screenshot ГѓВўГўв‚¬В Гўв‚¬в„ў page coordinates
  vp.addEventListener('pointerdown',()=>{vp.dataset.pressed='1'});
  vp.addEventListener('pointerup',(e)=>{
    vp.dataset.pressed='0';
    let img=recoveryDom.screenshot,imgRect=img.getBoundingClientRect();
    let x=e.clientX-imgRect.left,y=e.clientY-imgRect.top;
    let sx=img.naturalWidth/imgRect.width,sy=img.naturalHeight/imgRect.height;
    let px=Math.round(x*sx),py=Math.round(y*sy);
    // Ripple
    let r=document.createElement('div');r.className='click-ripple';
    r.style.left=(e.clientX-vp.getBoundingClientRect().left)+'px';
    r.style.top=(e.clientY-vp.getBoundingClientRect().top)+'px';
    recoveryDom.rippleLayer.appendChild(r);
    r.addEventListener('animationend',()=>r.remove());
    sendCmd('human_click',{x:px,y:py});
  });
  vp.addEventListener('selectstart',e=>e.preventDefault());
  // Text input ГѓВўГўв‚¬В Гўв‚¬в„ў Enter sends type + key
  recoveryDom.textInput.addEventListener('keydown',(e)=>{
    if(e.key==='Enter'){
      e.preventDefault();
      let t=recoveryDom.textInput.value.trim();
      if(t){sendCmd('human_type',{text:t});sendCmd('human_key',{key:'Enter'})}
      recoveryDom.textInput.value='';
    }else if(e.key==='Escape'){recoveryDom.textInput.value=''}
  });
  // Key buttons
  document.getElementById('keyTab').addEventListener('click',()=>sendCmd('human_key',{key:'Tab'}));
  document.getElementById('keyEnter').addEventListener('click',()=>{let t=recoveryDom.textInput.value.trim();recoveryDom.textInput.value='';if(t)sendCmd('human_type',{text:t});sendCmd('human_key',{key:'Enter'})});
  document.getElementById('keyEscape').addEventListener('click',()=>sendCmd('human_key',{key:'Escape'}));
  document.getElementById('keyBackspace').addEventListener('click',()=>sendCmd('human_key',{key:'Backspace'}));
  // Resume / Cancel
  recoveryDom.resumeBtn.addEventListener('click',()=>{sendCmd('resume_agent',{goal_id:recovery.goalId});closeRecoveryPanel()});
  recoveryDom.cancelBtn.addEventListener('click',()=>{if(confirm('Cancel this goal?')){sendCmd('cancel_goal',{goal_id:recovery.goalId});closeRecoveryPanel()}});
  // Keyboard: R=resume, Esc=cancel (only when input not focused)
  document.addEventListener('keydown',(e)=>{
    if(!recovery.active||document.activeElement===recoveryDom.textInput)return;
    if(e.key==='r'||e.key==='R'){e.preventDefault();recoveryDom.resumeBtn.click()}
    else if(e.key==='Escape'){e.preventDefault();recoveryDom.cancelBtn.click()}
  });
  recoveryWired=true;
}
function sendCmd(type,extra){
  if(!ws||!wsConnected||!recovery.sessionId)return;
  ws.send(JSON.stringify({type:type,session_id:recovery.sessionId,...extra}));
}
// ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Open / Close / Update ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬
function openRecoveryPanel(d){
  wireRecovery();
  recovery.active=true;
  recovery.sessionId=d.session_id||'';
  recovery.goalId=d.goal_id||'';
  recovery.goalDesc=d.goal_description||'';
  recovery.subGoal=d.sub_goal||'';
  recovery.stepCount=d.step_count||0;
  recovery.pageUrl=d.page_url||'';
  recovery.pausedAt=new Date();
  recovery.pauseReason=d.block_reason||'unknown';
  // Banner
  recoveryDom.banner.className='pause-banner'+(d.block_reason==='login_wall'||d.block_reason==='paywall'?' warning':'');
  recoveryDom.pauseText.textContent='AGENT PAUSED';
  recoveryDom.pauseReason.textContent=d.block_reason||'Escalation';
  // Session card
  recoveryDom.sessGoal.textContent=recovery.goalDesc||'---';
  recoveryDom.sessSubGoal.textContent=recovery.subGoal||'---';
  recoveryDom.sessSteps.textContent=String(recovery.stepCount);
  recoveryDom.sessUrl.textContent=recovery.pageUrl||'---';
  // Screenshot
  if(d.screenshot_base64){recoveryDom.screenshot.src='data:image/png;base64,'+d.screenshot_base64}
  recoveryDom.rippleLayer.innerHTML='';
  recoveryDom.textInput.value='';
  recoveryDom.overlay.classList.remove('hidden');
  recoveryDom.resumeBtn.classList.add('glow');
  // Timer
  if(recovery.timer)clearInterval(recovery.timer);
  recovery.timer=setInterval(updatePauseTimer,1000);
  updatePauseTimer();
  setTimeout(()=>recoveryDom.textInput.focus(),100);
  showToast('Agent paused ГѓВўГўвЂљВ¬Гўв‚¬Вќ '+recovery.pauseReason+'. Interact with the live page.','warning');
}
function closeRecoveryPanel(){
  recovery.active=false;
  if(recovery.timer){clearInterval(recovery.timer);recovery.timer=null}
  recoveryDom.overlay.classList.add('hidden');
  recoveryDom.screenshot.src='';
}
function updateLiveScreenshot(d){
  if(!recovery.active||d.session_id!==recovery.sessionId)return;
  if(recoveryDom.viewport.dataset.pressed==='1')return;
  if(d.data_base64){recoveryDom.screenshot.src='data:image/png;base64,'+d.data_base64}
}
function updatePauseTimer(){
  if(!recovery.pausedAt)return;
  let s=Math.floor((Date.now()-recovery.pausedAt)/1000);
  recoveryDom.sessPaused.textContent=Math.floor(s/60)+'m '+(s%60)+'s';
}
connectWS();
</script>
