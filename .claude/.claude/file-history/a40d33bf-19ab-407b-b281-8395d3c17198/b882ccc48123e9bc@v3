const API_KEY='dev-secret-key-123';
async function submitGoal(){
  let goal=document.getElementById('goalInput').value.trim();if(!goal)return;
  let btn=document.getElementById('submitBtn');btn.disabled=true;btn.textContent='Running...';
  try{
    let r=await fetch(API+'/api/v1/goals',{method:'POST',headers:{'Content-Type':'application/json','X-API-Key':API_KEY},body:JSON.stringify({description:goal,max_steps:50,context:fastMode?'mode=fast':''})});
    if(r.ok){let j=await r.json();goals[j.goal_id]={goal_id:j.goal_id,description:goal,status:j.status,progress:j.progress,created_at:Date.now()};document.getElementById('goalInput').value='';renderGoals();showToast('Goal created','success')}else{let t=await r.text();showToast('Failed: '+t,'error')}
  }catch(e){showToast('Error: '+e.message,'error')}
  btn.disabled=false;btn.textContent='ГѓВўГўв‚¬вЂњГ‚В¶ Run';
}
async function cancelGoal(id){
  try{
    let r=await fetch(API+'/api/v1/goals/'+id+'/cancel',{method:'POST',headers:{'X-API-Key':API_KEY}});
    if(r.ok){goals[id].status='failed';goals[id].progress=1;renderGoals();showToast('Goal cancelled','success')}else{let t=await r.text();showToast('Cancel failed: '+t,'error')}
  }catch(e){showToast('Error: '+e.message,'error')}
}
function renderGoals(){
  let entries=Object.entries(goals).sort((a,b)=>b[1].created_at-a[1].created_at),grid=document.getElementById('goalsGrid');
  if(!entries.length){grid.innerHTML='<div class="glass empty-state"><div class="empty-icon">ГѓВ°Г…ВёГ…ВЅГ‚ВЇ</div><p>No active goals. Submit a goal above to get started.</p></div>';return}
  document.getElementById('activeCount').textContent=entries.filter(([,g])=>g.status==='active').length;
  grid.innerHTML=entries.map(([id,g])=>{
    let pct=Math.round((g.progress||0)*100),sc=g.status==='completed'?'completed':g.status==='failed'?'failed':'';
    let sg=g.sub_goals||[],shtml=sg.length?('<div class="sub-goals">'+sg.map(s=>{let dc=s.status==='Done'?'done':s.status==='Active'?'active':s.status==='Blocked'?'blocked':'pending';return`<div class="sub-goal-item"><span class="sub-goal-dot ${dc}"></span>${e(s.description)}</div>`}).join('')+'</div>'):'';
    let cancelBtn = g.status==='active' || g.status==='blocked'
      ? `<button onclick="event.stopPropagation();cancelGoal('${id}')" style="position:absolute;top:16px;right:16px;background:var(--danger);color:#fff;border:none;border-radius:6px;padding:6px 14px;cursor:pointer;font-size:.78rem;font-weight:600;font-family:var(--font)">ГѓВўГ…вЂњГўв‚¬Вў Stop</button>`
      : '';
    return`<div class="glass goal-card ${sc}"><div class="goal-title">${e(g.description)}</div>${cancelBtn}<div class="goal-meta"><span>${pct}%</span><span style="text-transform:capitalize">${g.status}</span></div><div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>${shtml}</div>`
  }).join('')
}
function toggleMode(){fastMode=!fastMode;document.getElementById('modeBadge').textContent=fastMode?'Fast':'Thorough';document.getElementById('modeBadge').className='mode-badge '+(fastMode?'fast':'thorough');showToast(`Mode: ${fastMode?'Fast (skip Eyes)':'Thorough (full 5 Eyes)'}`,'success')}
function showToast(m,t){let el=document.createElement('div');el.className='toast '+t;el.textContent=m;document.body.appendChild(el);setTimeout(()=>el.remove(),4000)}
