<script>
const API = '';
let ws=null,goals={},wsConnected=false,fastMode=false;

function connectWS(){
  ws=new WebSocket(`ws://${location.host}/ws`);
  ws.onopen=()=>{wsConnected=true;document.getElementById('wsDot').className='status-dot connected';document.getElementById('wsStatus').textContent='Connected'};
  ws.onclose=()=>{wsConnected=false;document.getElementById('wsDot').className='status-dot disconnected';document.getElementById('wsStatus').textContent='Disconnected - reconnecting...';setTimeout(connectWS,2000)};
  ws.onmessage=(e)=>{try{handleEvent(JSON.parse(e.data))}catch(ex){}};
}
function handleEvent(d){
  if(d.type==='goal_created'){goals[d.goal_id]=d;renderGoals()}
  else if(d.type==='goal_update'){
    if(goals[d.goal_id]){goals[d.goal_id].progress=d.progress;goals[d.goal_id].status=d.status;if(d.sub_goals)goals[d.goal_id].sub_goals=d.sub_goals}else{goals[d.goal_id]=d}
    renderGoals();
    if(d.eye_updates)for(let[k,v]of Object.entries(d.eye_updates)){let el=document.getElementById('eye-'+k.replace('_','-'));if(el){el.className='glass eye-tile '+(v==='active'?'active':v==='error'?'error':v==='warning'?'warning':'');el.querySelector('.eye-status').textContent=v}}
  }else if(d.type==='eye_report'){let el=document.getElementById('eye-'+d.eye_name);if(el){el.className='glass eye-tile active';el.querySelector('.eye-status').textContent='active (confidence: '+(d.confidence||0).toFixed(2)+')'}}
  // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Error Recovery Events ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬
  else if(d.type==='session_paused'){openRecoveryPanel(d)}
