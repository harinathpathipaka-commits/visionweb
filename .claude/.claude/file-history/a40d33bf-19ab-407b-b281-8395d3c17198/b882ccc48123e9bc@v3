<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ANS ГѓВўГўвЂљВ¬Гўв‚¬Вќ Agent Nervous System</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0a0f;--surface:rgba(255,255,255,0.04);--border:rgba(255,255,255,0.08);
  --text:#e0e0e0;--text-dim:#7a7a8a;--accent:#6c5ce7;--accent-glow:rgba(108,92,231,0.25);
  --success:#00cec9;--warning:#fdcb6e;--danger:#ff7675;--radius:12px;
  --font:'Segoe UI',system-ui,-apple-system,sans-serif;
}
body{font-family:var(--font);background:var(--bg);color:var(--text);min-height:100vh}
body::before{content:'';position:fixed;top:-50%;left:-50%;width:200%;height:200%;
  background:radial-gradient(ellipse at 30% 20%,rgba(108,92,231,0.06) 0%,transparent 50%),
             radial-gradient(ellipse at 70% 80%,rgba(0,206,201,0.04) 0%,transparent 50%);
  pointer-events:none;z-index:0}
.container{max-width:1200px;margin:0 auto;padding:24px;position:relative;z-index:1}

.header{text-align:center;padding:40px 0 32px}
.header h1{font-size:2rem;font-weight:600;background:linear-gradient(135deg,var(--accent),var(--success));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.header p{color:var(--text-dim);margin-top:8px;font-size:.95rem}

.glass{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);backdrop-filter:blur(20px);transition:all .3s}
.glass:hover{border-color:rgba(255,255,255,0.14);box-shadow:0 4px 24px rgba(0,0,0,0.3)}

.status-strip{display:flex;gap:20px;margin-bottom:24px;padding:16px 20px;font-size:.88rem;align-items:center;flex-wrap:wrap}
.status-dot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:8px}
.status-dot.connected{background:var(--success);box-shadow:0 0 8px var(--success)}
.status-dot.disconnected{background:var(--danger);box-shadow:0 0 8px var(--danger)}
.mode-badge{padding:4px 12px;border-radius:20px;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:1px}
.mode-badge.fast{background:rgba(0,206,201,0.15);color:var(--success)}
.mode-badge.thorough{background:rgba(108,92,231,0.15);color:var(--accent)}

.goal-bar{display:flex;gap:12px;padding:20px;margin-bottom:24px}
.goal-bar input{flex:1;background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);padding:14px 18px;font-size:1rem;font-family:var(--font);outline:none;transition:all .25s}
.goal-bar input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-glow)}
.goal-bar input::placeholder{color:var(--text-dim)}
.goal-bar button{background:var(--accent);color:#fff;border:none;border-radius:var(--radius);padding:14px 28px;cursor:pointer;font-size:1rem;font-weight:600;font-family:var(--font);transition:all .25s;white-space:nowrap}
.goal-bar button:hover{background:#7c6ff7;box-shadow:0 0 24px var(--accent-glow);transform:translateY(-1px)}
.goal-bar button:disabled{opacity:.5;cursor:not-allowed;transform:none}

.eyes-panel{padding:20px;margin-bottom:16px}
.eyes-panel h2{font-size:1.1rem;font-weight:600;margin-bottom:16px}
.eyes-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:12px}
.eye-tile{padding:14px;text-align:center}
.eye-tile .eye-icon{font-size:1.5rem;margin-bottom:8px}
.eye-tile .eye-name{font-weight:600;font-size:.85rem;margin-bottom:4px}
.eye-tile .eye-status{font-size:.75rem;color:var(--text-dim)}
.eye-tile.active{border-color:var(--accent);background:rgba(108,92,231,0.1)}
.eye-tile.warning{border-color:var(--warning);background:rgba(253,203,110,0.1)}
.eye-tile.error{border-color:var(--danger);background:rgba(255,118,117,0.1)}

.goals-grid{display:grid;grid-template-columns:1fr;gap:16px;margin-bottom:24px}
.goal-card{padding:20px;position:relative;overflow:hidden}
.goal-card::before{content:'';position:absolute;top:0;left:0;width:4px;height:100%;background:var(--accent);border-radius:4px 0 0 4px}
.goal-card.completed::before{background:var(--success)}
.goal-card.failed::before{background:var(--danger)}
.goal-card .goal-title{font-weight:600;font-size:1rem;margin-bottom:12px;line-height:1.4;padding-right:80px}
.goal-card .goal-meta{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;font-size:.82rem;color:var(--text-dim)}
.goal-card .progress-bar{height:6px;background:rgba(255,255,255,0.06);border-radius:3px;overflow:hidden;margin-bottom:8px}
.goal-card .progress-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--success));border-radius:3px;transition:width .5s ease}
.goal-card .sub-goals{margin-top:10px}
.goal-card .sub-goal-item{display:flex;align-items:center;gap:8px;padding:4px 0;font-size:.8rem;color:var(--text-dim)}
.sub-goal-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.sub-goal-dot.done{background:var(--success)}
.sub-goal-dot.active{background:var(--warning);animation:pulse 1.5s ease infinite}
.sub-goal-dot.pending{background:rgba(255,255,255,0.15)}
.sub-goal-dot.blocked{background:var(--danger)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

.empty-state{text-align:center;padding:60px 20px;color:var(--text-dim)}
.empty-state .empty-icon{font-size:3rem;margin-bottom:16px;opacity:.4}

.toast{position:fixed;bottom:20px;right:20px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:12px 20px;backdrop-filter:blur(20px);animation:slideIn .3s ease;z-index:100;font-size:.85rem}
.toast.error{border-color:var(--danger)}
.toast.success{border-color:var(--success)}
@keyframes slideIn{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}

@media(max-width:640px){.container{padding:12px}.header h1{font-size:1.5rem}.goal-bar{flex-direction:column}}

/* ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Error Recovery Overlay ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ */
.live-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px);z-index:200;display:flex;align-items:center;justify-content:center;animation:ovIn .3s ease}
.live-overlay.hidden{display:none}
@keyframes ovIn{from{opacity:0}to{opacity:1}}

.live-panel{width:min(95vw,1100px);max-height:95vh;padding:0;overflow:hidden;display:flex;flex-direction:column;animation:pnlIn .35s cubic-bezier(.16,1,.3,1)}
@keyframes pnlIn{from{transform:translateY(40px) scale(.97);opacity:0}to{transform:translateY(0) scale(1);opacity:1}}

.pause-banner{display:flex;align-items:center;gap:12px;padding:14px 20px;background:rgba(255,118,117,.12);border-bottom:1px solid rgba(255,118,117,.3);font-weight:600;font-size:.92rem;animation:banPulse 2s ease-in-out infinite}
@keyframes banPulse{0%,100%{background:rgba(255,118,117,.12)}50%{background:rgba(255,118,117,.22)}}
.pause-banner.warning{background:rgba(253,203,110,.12);border-bottom-color:rgba(253,203,110,.3);animation-name:banPulseWarn}
@keyframes banPulseWarn{0%,100%{background:rgba(253,203,110,.12)}50%{background:rgba(253,203,110,.22)}}
.pause-banner .pause-icon{font-size:1.3rem}
.pause-banner .pause-text{color:var(--danger);text-transform:uppercase;letter-spacing:1px;white-space:nowrap}
.pause-banner.warning .pause-text{color:var(--warning)}
.pause-banner .pause-reason{color:var(--text-dim);font-weight:400;margin-left:auto}

.screenshot-viewport{position:relative;background:#000;overflow:auto;max-height:55vh;display:flex;align-items:flex-start;justify-content:center;cursor:crosshair;user-select:none;border-left:3px solid var(--border);border-right:3px solid var(--border)}
.screenshot-img{display:block;width:100%;height:auto;pointer-events:none}
.ripple-layer{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:2}
.click-ripple{position:absolute;width:20px;height:20px;margin-left:-10px;margin-top:-10px;border-radius:50%;background:rgba(108,92,231,.6);animation:ripOut .6s ease-out forwards}
@keyframes ripOut{0%{transform:scale(0);opacity:1}100%{transform:scale(6);opacity:0}}

.action-bar{display:flex;align-items:center;gap:12px;padding:14px 20px;border-top:1px solid var(--border);flex-wrap:wrap}
.input-group{display:flex;align-items:center;gap:6px;flex:1;min-width:0}
.text-input{flex:1;min-width:140px;background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);padding:10px 14px;font-size:.9rem;font-family:var(--font);outline:none;transition:border-color .25s}
.text-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-glow)}
.text-input::placeholder{color:var(--text-dim)}
.key-btn{background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:var(--radius);color:var(--text-dim);padding:8px 14px;font-size:.78rem;font-family:var(--font);cursor:pointer;transition:all .2s;white-space:nowrap}
.key-btn:hover{background:rgba(255,255,255,.1);color:var(--text);border-color:rgba(255,255,255,.14)}
.key-btn:active{background:var(--accent);color:#fff;border-color:var(--accent);transform:scale(.95)}
.resume-group{display:flex;gap:10px;align-items:center}
.cancel-btn{padding:10px 20px;border:1px solid var(--border);border-radius:var(--radius);background:transparent;color:var(--text-dim);font-size:.85rem;font-family:var(--font);cursor:pointer;transition:all .2s}
.cancel-btn:hover{color:var(--danger);border-color:var(--danger);background:rgba(255,118,117,.08)}
.resume-btn{padding:12px 32px;border:none;border-radius:var(--radius);background:var(--success);color:#000;font-size:.95rem;font-weight:700;font-family:var(--font);cursor:pointer;transition:all .25s;white-space:nowrap;letter-spacing:.3px}
.resume-btn:hover{background:#00e6d9;box-shadow:0 0 30px rgba(0,206,201,.4);transform:translateY(-1px)}
.resume-btn:active{transform:scale(.97)}
.resume-btn.glow{animation:resGlow 2s ease-in-out infinite}
@keyframes resGlow{0%,100%{box-shadow:0 0 0 0 rgba(0,206,201,.5)}50%{box-shadow:0 0 16px 4px rgba(0,206,201,.35)}}

.session-card{padding:14px 20px;border-top:1px solid var(--border);display:flex;flex-direction:column;gap:6px}
.session-row{display:flex;align-items:baseline;gap:12px}
.session-label{font-size:.75rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:.5px;min-width:70px;flex-shrink:0}
.session-value{font-size:.85rem;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.session-meta{display:flex;gap:24px;margin-top:4px}
.session-meta .session-label{min-width:auto;margin-right:6px}
.url-truncate{max-width:320px;display:inline-block}

@media(max-width:640px){.action-bar{flex-direction:column;align-items:stretch}.resume-group{flex-direction:column}.cancel-btn,.resume-btn{width:100%;text-align:center}.session-meta{flex-direction:column;gap:4px}.pause-banner{flex-wrap:wrap}.pause-reason{margin-left:0;width:100%;margin-top:4px}.screenshot-viewport{max-height:35vh}}
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <h1>Agent Nervous System</h1>
    <p>Purpose-built browser for AI agents ГѓВўГўвЂљВ¬Гўв‚¬Вќ submit goals, watch live, see results</p>
  </div>

  <div class="glass status-strip">
    <div>
      <span class="status-dot disconnected" id="wsDot"></span>
      <span id="wsStatus">Connecting...</span>
    </div>
    <div><span class="mode-badge thorough" id="modeBadge">Thorough</span></div>
    <div style="margin-left:auto;color:var(--text-dim)">Active: <strong id="activeCount">0</strong></div>
  </div>

  <div class="glass goal-bar">
    <input type="text" id="goalInput" placeholder="What should the agent do? e.g., Search for flights from Delhi to Mumbai on June 5" autofocus>
    <button id="submitBtn" onclick="submitGoal()">ГѓВўГўв‚¬вЂњГ‚В¶ Run</button>
    <button onclick="toggleMode()" style="background:transparent;border:1px solid var(--border);font-size:.8rem;padding:14px 16px" title="Toggle fast/thorough mode">Fast</button>
  </div>

  <!-- ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Live View Panel ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ -->
  <div class="glass live-panel-section" id="liveView" style="display:none;padding:20px;margin-bottom:16px">
    <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
      <h2 style="font-size:1.1rem;font-weight:600;margin:0">ГѓВ°Г…ВёГўв‚¬Е“Г‚Вє Live View</h2>
      <span style="font-size:.78rem;color:var(--text-dim)" id="liveStep">---</span>
      <span id="liveStatus" style="font-size:.78rem;padding:3px 10px;border-radius:20px;background:rgba(0,206,201,0.15);color:var(--success)">running</span>
    </div>
    <div style="display:flex;gap:16px;margin-top:16px;flex-wrap:wrap">
      <div style="flex:1;min-width:300px;background:#000;border-radius:8px;overflow:hidden;max-height:400px;display:flex;align-items:center;justify-content:center">
        <img id="liveViewScreenshot" src="" alt="Live agent view" style="width:100%;height:auto;display:block">
      </div>
      <div style="flex:1;min-width:250px;display:flex;flex-direction:column;gap:10px;font-size:.85rem">
        <div><span style="color:var(--text-dim)">Action:</span> <span id="liveAction" style="font-weight:600">---</span></div>
        <div><span style="color:var(--text-dim)">Sub-goal:</span> <span id="liveSubGoal">---</span></div>
        <div><span style="color:var(--text-dim)">Page:</span> <span id="livePage" style="word-break:break-all">---</span></div>
        <div><span style="color:var(--text-dim)">URL:</span> <span id="liveUrl" style="font-size:.78rem;color:var(--text-dim);word-break:break-all">---</span></div>
      </div>
    </div>
  </div>

  <div class="glass eyes-panel">
    <h2>5 Eyes ГѓВўГўвЂљВ¬Гўв‚¬Вќ Perception</h2>
    <div class="eyes-grid">
      <div class="glass eye-tile" id="eye-dom_reader"><div class="eye-icon">ГѓВ°Г…ВёГўв‚¬ВќГ‚ВЌ</div><div class="eye-name">DOM Reader</div><div class="eye-status">idle</div></div>
      <div class="glass eye-tile" id="eye-vision"><div class="eye-icon">ГѓВ°Г…ВёГўв‚¬ЛњГ‚ВЃ</div><div class="eye-name">Vision</div><div class="eye-status">idle</div></div>
      <div class="glass eye-tile" id="eye-page_diff"><div class="eye-icon">ГѓВўГ…ВЎГ‚ВЎ</div><div class="eye-name">Page Diff</div><div class="eye-status">idle</div></div>
      <div class="glass eye-tile" id="eye-goal_verifier"><div class="eye-icon">ГѓВўГ…вЂњГўв‚¬В¦</div><div class="eye-name">Goal Verifier</div><div class="eye-status">idle</div></div>
      <div class="glass eye-tile" id="eye-error_detector"><div class="eye-icon">ГѓВ°Г…ВёГ…ВЎГ‚ВЁ</div><div class="eye-name">Error Detector</div><div class="eye-status">idle</div></div>
    </div>
  </div>

  <div class="goals-grid" id="goalsGrid">
    <div class="glass empty-state"><div class="empty-icon">ГѓВ°Г…ВёГ…ВЅГ‚ВЇ</div><p>No active goals. Submit a goal above to get started.</p></div>
  </div>
</div>

