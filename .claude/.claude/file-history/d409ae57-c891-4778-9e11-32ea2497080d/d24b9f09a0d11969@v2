"""Tests for Phase 6: Smart Query — data pipeline integration."""
from __future__ import annotations

import os
import sqlite3
import tempfile

import pytest
from fastapi.testclient import TestClient

from src.api import app
from src.smart_query import resolve_variables, run_smart_query
from src.storage import init_storage


@pytest.fixture
def client():
    return TestClient(app)


@pytest.fixture
def populated_db():
    """Create a DB with sample observations for testing."""
    fd, path = tempfile.mkstemp(suffix=".db")
    os.close(fd)
    init_storage(path)

    # Insert sample observations
    with sqlite3.connect(path) as conn:
        conn.execute("DELETE FROM observation_ledger")
        for i in range(50):
            ts = f"2024-{(i%12)+1:02d}-01T00:00:00Z"
            conn.execute(
                "INSERT INTO observation_ledger (variable, value, unit, timestamp, entity_id, quality_score, provenance_json, created_at) "
                "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
                ("tenure", float(i + 1), "months", ts, None, 1.0, "{}", ts),
            )
            conn.execute(
                "INSERT INTO observation_ledger (variable, value, unit, timestamp, entity_id, quality_score, provenance_json, created_at) "
                "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
                ("churn", 0.4 - 0.005 * i + (i % 5) * 0.01, "percentage",
                 ts, None, 1.0, "{}", ts),
            )

    yield path
    try:
        os.unlink(path)
    except PermissionError:
        pass


# ── Variable Resolution ─────────────────────────────────────────────────────


class TestVariableResolution:
    def test_resolves_ledger_variables(self, populated_db):
        result = resolve_variables(populated_db, "how does churn relate to tenure")
        assert result["method"] != "no_data"
        assert result["n_obs"] >= 3
        assert result["y_var"] is not None

    def test_question_with_no_data(self):
        fd, path = tempfile.mkstemp(suffix=".db")
        os.close(fd)
        init_storage(path)
        try:
            result = resolve_variables(path, "what drives revenue")
            assert result["method"] == "no_data"
            assert result["n_obs"] == 0
        finally:
            try:
                os.unlink(path)
            except PermissionError:
                pass

    def test_extracts_domain(self, populated_db):
        result = resolve_variables(populated_db, "what is saas churn rate by tenure")
        assert result["domain"] in ("finance.saas.smb", "general")


# ── Smart Query ─────────────────────────────────────────────────────────────


class TestSmartQuery:
    def test_run_smart_query_with_data(self, populated_db):
        result = run_smart_query(populated_db, "how does churn change with tenure")
        assert "question" in result
        assert "answer" in result
        assert "fit" in result
        assert result["n_observations"] >= 3
        assert isinstance(result["answer"], str)
        assert len(result["answer"]) > 10

    def test_run_smart_query_no_data(self):
        fd, path = tempfile.mkstemp(suffix=".db")
        os.close(fd)
        init_storage(path)
        try:
            result = run_smart_query(path, "what drives MRR")
            assert result["method"] == "no_data"
            assert "Upload data" in result["answer"]
        finally:
            try:
                os.unlink(path)
            except PermissionError:
                pass

    def test_run_smart_query_with_evaluate_at(self, populated_db):
        result = run_smart_query(populated_db, "churn vs tenure", evaluate_at=24.0)
        assert result["fit"] is not None
        assert result["evaluated_at"] == 24.0

    def test_run_smart_query_single_ledger_variable(self, populated_db):
        """Query where only the target exists in ledger."""
        result = run_smart_query(populated_db, "what happened to churn")
        assert result["fit"] is not None or result["method"] == "ledger_time_series"
        assert "churn" in result.get("y_variable", "")


# ── Smart Query API ─────────────────────────────────────────────────────────


class TestSmartQueryAPI:
    def test_query_endpoint_with_data(self, client, populated_db):
        # Override DB path via env
        os.environ["EL_DB_PATH"] = populated_db
        try:
            resp = client.post("/v2/query", json={
                "question": "how does churn change with tenure",
                "evaluate_at": 24.0,
            })
            # May be 200 (data found) or 404 (no ledger variables due to db path mismatch)
            assert resp.status_code in (200, 404)
        finally:
            os.environ.pop("EL_DB_PATH", None)

    def test_query_endpoint_empty_question(self, client):
        resp = client.post("/v2/query", json={"question": "ab"})
        assert resp.status_code == 422  # Min 3 chars

    def test_query_endpoint_short_question_rejected(self, client):
        resp = client.post("/v2/query", json={"question": "xy"})
        assert resp.status_code == 422
