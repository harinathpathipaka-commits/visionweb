    random_seed: Optional[int] = Field(default=None, ge=0, le=2**32 - 1)


class MultiSolveResponse(BaseModel):
    trace_id: str
    r2: float
    adj_r2: float
    aic: float
    coefficients: Dict[str, float]
    std_errors: Dict[str, float]
    p_values: Dict[str, float]
    variable_importance: Dict[str, float]
    residual_std: float
    n_obs: int
    answer: Optional[float] = None
    prose: str = ""


@app.post("/v2/solve", response_model=MultiSolveResponse)
async def multiv_solve_endpoint(body: MultiSolveRequest, request: Request):
    """Multi-variable solve: y = f(x1, x2, x3, ...). Accepts dicts of variable arrays."""
    if body.target not in body.variables:
        raise HTTPException(400, f"Target '{body.target}' not in variables dict")
    if len(body.variables) < 2:
        raise HTTPException(400, "At least one predictor and one target variable required")

    predictors = {k: v for k, v in body.variables.items() if k != body.target}
    target_values = body.variables[body.target]

    if len(target_values) < 3:
        raise HTTPException(422, "Need at least 3 observations")

    # Check for zero variance
    for name, vals in predictors.items():
        if len(set(vals)) <= 1:
            raise HTTPException(422, f"'{name}' has zero variance")

    from .categorical import auto_encode
    from .multivar import fit_multivariate as _fit_mv, predict_multivariate as _pred_mv
    encoded = auto_encode(predictors)

    result = _fit_mv(encoded, target_values)

    trace_id = str(uuid.uuid4())

    # Evaluate at specified point or use means
    answer = None
    if body.evaluate_at:
        encoded_eval = {k: body.evaluate_at.get(k, 0.0) for k in predictors}
        from .categorical import auto_encode as ae2
        # Handle categorical encoding for evaluation point
        answer = _pred_mv(encoded_eval, result["coefficients"])

    # Prose
    top_var = max(result["variable_importance"].items(), key=lambda x: x[1]) if result["variable_importance"] else ("unknown", 0)
    importance_pct = f"{top_var[1]*100:.1f}%" if result["variable_importance"] else "N/A"
    prose = (
        f"Multi-variable model fitted (R²={result['adj_r2']:.3f}, n={result['n_obs']}). "
        f"Top driver: '{top_var[0]}' explains {importance_pct} of explained variance."
        + (f" Projected value: {answer:.2f}." if answer is not None else "")
    )

    return MultiSolveResponse(
        trace_id=trace_id,
        r2=round(result["r2"], 6),
        adj_r2=round(result["adj_r2"], 6),
        aic=round(result["aic"], 4),
        coefficients={k: round(v, 6) for k, v in result["coefficients"].items()},
        std_errors={k: round(v, 6) for k, v in result["std_errors"].items()},
        p_values={k: round(v, 6) for k, v in result["p_values"].items()},
        variable_importance=result["variable_importance"],
        residual_std=round(result["residual_std"], 6),
        n_obs=result["n_obs"],
        answer=round(answer, 6) if answer is not None else None,
        prose=prose,
    )


