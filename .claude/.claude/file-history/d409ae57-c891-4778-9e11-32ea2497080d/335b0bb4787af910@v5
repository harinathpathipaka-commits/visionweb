    ci_95_upper: Optional[float] = None
    uncertainty_std: Optional[float] = None


@app.post("/v2/what-if", response_model=WhatIfResponse)
async def what_if_endpoint(body: WhatIfRequest, request: Request):
    """Evaluate a stored equation at an arbitrary x-value. No re-fitting — fast."""
    db_path = _db_path()
    init_storage(db_path)

    with db_transaction(db_path, readonly=True) as conn:
        row = conn.execute(
            """SELECT e.equation_id, ev.form_family, ev.sympy_ast, ev.parameters_json, ev.stats_json
               FROM equation_library e
               JOIN equation_versions ev ON e.active_version_id = ev.version_id
               WHERE e.equation_id = ?""",
            (body.equation_id,),
        ).fetchone()

    if not row:
        raise HTTPException(404, f"Equation {body.equation_id} not found or has no active version")

    family = row[1]
    sympy_expr = row[2]
    parameters = json.loads(row[3])
    stats_raw = json.loads(row[4] or "{}")

    from .models import EquationFit, FitStats
    from .compute import evaluate_equation, sensitivity_map
    from .probabilistic import laplace_approximation

    stats = FitStats(
        r2_adj=float(stats_raw.get("r2_adj", 0)),
        holdout_mape=float(stats_raw.get("holdout_mape", float("inf"))),
        aic=float(stats_raw.get("aic", float("inf"))),
        residual_random=bool(stats_raw.get("residual_random", False)),
        n_obs=int(stats_raw.get("n_obs", 0)),
    )
    equation = EquationFit(family=family, parameters=parameters, stats=stats, sympy_expr=sympy_expr)

    compute = evaluate_equation(equation, body.x_value)
    prob = laplace_approximation(equation, body.x_value, n_samples=5000)

    try:
        sens = sensitivity_map(equation, body.x_value)
    except Exception:
        sens = {}

    return WhatIfResponse(
        equation_id=body.equation_id,
        family=family,
        sympy_expr=sympy_expr,
        parameters=parameters,
        x_value=body.x_value,
        answer=compute.answer,
        derivative=compute.derivatives.get("dY/dX"),
        elasticity=sens.get("elasticity_approx"),
        ci_95_lower=round(prob.ci_95[0], 6),
        ci_95_upper=round(prob.ci_95[1], 6),
        uncertainty_std=round(prob.std, 6),
    )


class GraphPathResponse(BaseModel):
    source: str
    target: str
    path_found: bool
    nodes: List[str] = []
    edges: List[Dict[str, Any]] = []
