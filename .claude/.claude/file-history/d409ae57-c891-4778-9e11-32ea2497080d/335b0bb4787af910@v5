@app.post("/v2/graph/path", response_model=GraphPathResponse)
async def graph_path_endpoint(source: str = Query(...), target: str = Query(...)):
    """Find a derivation path through the equation graph from source to target variable."""
    from .pipeline import get_equation_graph
    graph = get_equation_graph()
    path = graph.find_path(source, target)
    if path is None:
        return GraphPathResponse(source=source, target=target, path_found=False)
    edges = [{"source": e.source, "target": e.target, "equation_id": e.equation_id,
               "family": e.family, "sympy_expr": e.sympy_expr} for e in path.edges]
    return GraphPathResponse(
        source=source, target=target, path_found=True,
        nodes=path.nodes, edges=edges,
        cumulative_uncertainty=path.cumulative_uncertainty,
    )


