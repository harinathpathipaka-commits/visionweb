from __future__ import annotations

import math
from typing import Dict, List, Optional, Tuple

import numpy as np
from scipy.optimize import least_squares
from scipy.stats import norm

from .models import EquationFit, ProbabilisticResult
from .fitting import _model_fn, _initial_guess


def _fit_family(
    family: str, x: np.ndarray, y: np.ndarray
) -> Optional[Tuple[np.ndarray, np.ndarray]]:
    """Fit a single family and return (params, jacobian_at_solution)."""
    try:
        init = _initial_guess(x, y, family)
        fn = _model_fn(x, family)

        def residual(p: np.ndarray) -> np.ndarray:
            return fn(tuple(p), x) - y

        result = least_squares(residual, np.array(init), method="trf", loss="soft_l1", max_nfev=2000)

        if not result.success or result.jac is None:
            return None
        return result.x, result.jac
    except Exception:
        return None


def _hessian_from_jacobian(jac: np.ndarray, residuals: Optional[np.ndarray] = None) -> np.ndarray:
    """Compute parameter covariance from Jacobian matrix at the solution.

    Uses J^T J to approximate the Hessian. If residuals are provided, estimates
    sigma^2 from RSS/(n-p). Otherwise uses unscaled (J^T J)^{-1}.
    """
    JtJ = jac.T @ jac
    n = jac.shape[0]
    p = jac.shape[1]
    if residuals is not None and len(residuals) == n:
        rss = float(np.sum(np.asarray(residuals, dtype=np.float64) ** 2))
        sigma2 = rss / max(n - p, 1)
    else:
        sigma2 = 1.0 / max(n, 1)
    try:
        cov = sigma2 * np.linalg.inv(JtJ)
        eigvals = np.linalg.eigvalsh(cov)
        if np.any(eigvals <= 0):
            cov += np.eye(p) * max(float(np.max(np.abs(cov))) * 1e-8, 1e-12)
        return cov
    except np.linalg.LinAlgError:
        return np.eye(p) * 1e-4


def laplace_approximation(
    equation: EquationFit, x_value: float, n_samples: int = 10000
) -> ProbabilisticResult:
    params_list = list(equation.parameters.values())
    n_params = len(params_list)
    cov = np.eye(n_params) * 0.01

    try:
        mean_vec = np.array(params_list)
        samples = np.random.multivariate_normal(mean_vec, cov, size=n_samples)
    except np.linalg.LinAlgError:
        samples = np.tile(np.array(params_list), (n_samples, 1))

    param_names = list(equation.parameters.keys())
    answers = np.zeros(n_samples)
    fn = _model_fn(np.array([x_value]), equation.family)

    for i in range(n_samples):
        sample_params = dict(zip(param_names, samples[i]))
        try:
            y_pred = fn(tuple(samples[i]), np.array([x_value]))
            answers[i] = float(y_pred[0])
        except (OverflowError, ValueError):
            answers[i] = float(np.nan)

    valid = answers[~np.isnan(answers)]
    if len(valid) == 0:
        mean_val = float(equation.parameters.get("a", 1.0) * x_value)
        return ProbabilisticResult(mean=mean_val, std=mean_val * 0.1, ci_95=(mean_val * 0.8, mean_val * 1.2), tail_risk=None)

    mean_val = float(np.mean(valid))
    std_val = float(np.std(valid))
    ci_95 = (float(np.percentile(valid, 2.5)), float(np.percentile(valid, 97.5)))
    tail_risk = float(np.mean(valid < 0)) if mean_val > 0 else None

    return ProbabilisticResult(mean=mean_val, std=std_val, ci_95=ci_95, tail_risk=tail_risk)


def laplace_from_fit(
    params: Dict[str, float],
    covariance: np.ndarray,
    equation: EquationFit,
    x_value: float,
    n_samples: int = 10000,
    residual_std: float = 0.0,
) -> ProbabilisticResult:
    param_names = list(params.keys())
    mean_vec = np.array([params[name] for name in param_names])

    try:
        samples = np.random.multivariate_normal(mean_vec, covariance, size=n_samples)
    except np.linalg.LinAlgError:
        samples = np.tile(mean_vec, (n_samples, 1))

    fn = _model_fn(np.array([x_value]), equation.family)
    answers = np.zeros(n_samples)
    rng = np.random.default_rng()

    for i in range(n_samples):
        try:
            y_pred = fn(tuple(samples[i]), np.array([x_value]))
            noise = rng.normal(0.0, residual_std) if residual_std > 0 else 0.0
            answers[i] = float(y_pred[0]) + noise
        except (OverflowError, ValueError):
            answers[i] = float(np.nan)

    valid = answers[~np.isnan(answers)]
    if len(valid) == 0:
        mean_val = float(params.get("a", 1.0) * x_value)
        return ProbabilisticResult(mean=mean_val, std=mean_val * 0.1, ci_95=(mean_val * 0.8, mean_val * 1.2), tail_risk=None)

    mean_val = float(np.mean(valid))
    std_val = float(np.std(valid))
    ci_95 = (float(np.percentile(valid, 2.5)), float(np.percentile(valid, 97.5)))
    tail_risk = float(np.mean(valid < 0)) if mean_val > 0 else None

    return ProbabilisticResult(mean=mean_val, std=std_val, ci_95=ci_95, tail_risk=tail_risk)


def bayesian_model_averaging(
    candidates: List[EquationFit], x_value: float, n_samples: int = 5000
) -> ProbabilisticResult:
    if not candidates:
        return ProbabilisticResult(mean=0.0, std=0.0, ci_95=(0.0, 0.0), tail_risk=None)

    aic_vals = np.array([c.stats.aic for c in candidates])
    if np.all(np.isinf(aic_vals)):
        weights = np.ones(len(candidates)) / len(candidates)
    else:
        min_aic = np.min(aic_vals[~np.isinf(aic_vals)])
        aic_adj = np.where(np.isinf(aic_vals), min_aic + 100, aic_vals)
        weights = np.exp(-0.5 * (aic_adj - min_aic))
        weights /= weights.sum()

    all_answers: List[float] = []
    all_weights: List[float] = []

    for candidate, weight in zip(candidates, weights):
        prob = laplace_approximation(candidate, x_value, n_samples=max(n_samples // len(candidates), 100))
        all_answers.append(prob.mean)
        all_weights.append(weight)

    all_answers_arr = np.array(all_answers)
    all_weights_arr = np.array(all_weights)

    weighted_mean = float(np.average(all_answers_arr, weights=all_weights_arr))
    weighted_var = float(np.average((all_answers_arr - weighted_mean) ** 2, weights=all_weights_arr))
    weighted_std = math.sqrt(weighted_var)

    sorted_answers = np.sort(all_answers_arr)
    sorted_w = all_weights_arr[np.argsort(all_answers_arr)]
    cumsum = np.cumsum(sorted_w) / sorted_w.sum()
    ci_low_idx = np.searchsorted(cumsum, 0.025)
    ci_high_idx = np.searchsorted(cumsum, 0.975)

    ci_low = float(sorted_answers[min(ci_low_idx, len(sorted_answers) - 1)])
    ci_high = float(sorted_answers[min(ci_high_idx, len(sorted_answers) - 1)])

    return ProbabilisticResult(
        mean=weighted_mean,
        std=weighted_std,
        ci_95=(ci_low, ci_high),
        tail_risk=None,
    )


def tail_risk(prob_result: ProbabilisticResult, threshold: float) -> float:
    z = (threshold - prob_result.mean) / max(prob_result.std, 1e-10)
    return float(norm.cdf(z))
