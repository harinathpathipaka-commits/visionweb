"""Answer all 6 enterprise questions using Store Sales data."""
from __future__ import annotations

import sys, os
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', 'src'))
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..'))

import numpy as np
from collections import defaultdict
from src.csv_analyzer import read_csv_columns
from src.multivar import fit_multivariate
from src.categorical import auto_encode, clean_column


def main():
    csv_path = os.path.join(os.path.dirname(__file__), '..', 'datasets', 'store_sales', 'train.csv')

    columns, col_order = read_csv_columns(csv_path, max_rows=100000)
    n_rows = max(len(v) for v in columns.values())
    print(f"Loaded {n_rows} rows, {len(col_order)} columns")

    cleaned = {n: clean_column(v) for n, v in columns.items()}
    target_raw = np.array([float(v) if v != 'missing' else 0.0 for v in cleaned['sales']], dtype=float)
    onpromo_raw = np.array([float(v) if v not in (None, 'missing', '') else 0.0
                             for v in cleaned['onpromotion']], dtype=float)

    # Skip date/id — date explodes into too many one-hot columns
    pred_cols = {k: v for k, v in cleaned.items() if k not in ('date', 'id', 'sales')}
    encoded = auto_encode(pred_cols)
    print(f"Encoded: {len(encoded)} predictors")

    # ---- Q1: What variable most affects sales? ----
    print('\n' + '='*60)
    print('Q1: WHAT VARIABLE MOST AFFECTS SALES?')
    print('='*60)
    fit = fit_multivariate(encoded, target_raw)
    imp = fit.get('variable_importance', {})
    coefs = fit.get('coefficients', {})
    if imp:
        for i, (var, val) in enumerate(sorted(imp.items(), key=lambda x: abs(x[1]), reverse=True)[:5]):
            print(f"  #{i+1}: {var}  importance={val:.4f}")
    else:
        for i, (var, val) in enumerate(sorted(coefs.items(), key=lambda x: abs(x[1]), reverse=True)[:5]):
            print(f"  #{i+1}: {var}  coef={val:.4f}")

    # ---- Q2: How sensitive is sales to promotions? ----
    print('\n' + '='*60)
    print('Q2: HOW SENSITIVE IS SALES TO PROMOTIONS?')
    print('='*60)
    promo_yes = onpromo_raw > 0
    promo_no = ~promo_yes
    n_promo = int(promo_yes.sum())
    print(f"  Promo rows in sample: {n_promo}/{n_rows} ({n_promo/n_rows*100:.1f}%)")
    if promo_yes.any() and promo_no.any():
        avg_no = float(np.mean(target_raw[promo_no]))
        avg_yes = float(np.mean(target_raw[promo_yes]))
        print(f"  Avg sales without promo: ${avg_no:.2f}")
        print(f"  Avg sales with promo:    ${avg_yes:.2f}")
        print(f"  Absolute lift:           ${avg_yes - avg_no:+.2f}")
        print(f"  Relative lift:           {(avg_yes/avg_no - 1)*100:+.1f}%")
    # OLS coefficient for onpromotion from full model
    promo_key = 'onpromotion'
    if promo_key in coefs:
        print(f"  OLS marginal effect:     {coefs[promo_key]:.4f} per promo unit")
    else:
        # Fit separately
        sf = fit_multivariate({'onpromotion': onpromo_raw.tolist()}, target_raw.tolist())
        print(f"  OLS marginal effect:     {sf['coefficients'].get('onpromotion', 0):.4f} per promo unit")
    if n_promo == 0:
        print("  (NOTE: no promotions in this sample slice — promo is very sparse)")

    # ---- Q3: What happens if top driver rises 15%? ----
    print('\n' + '='*60)
    print('Q3: WHAT HAPPENS IF TOP DRIVER CHANGES 15%? (WHAT-IF)')
    print('='*60)
    top_vars = sorted(imp.items(), key=lambda x: abs(x[1]), reverse=True) if imp else []
    # Skip one-hot encoded family_* columns, pick a continuous driver
    top_cont = None
    for var, _ in top_vars:
        if not var.startswith('family_') and var in encoded:
            vals = np.array(encoded[var], dtype=float)
            if len(np.unique(vals)) > 2:
                top_cont = var
                break
    if top_cont is None:
        top_cont = list(encoded.keys())[0]

    x = np.array(encoded[top_cont], dtype=float)
    x_mean = float(np.mean(x))
    y = target_raw
    sf = fit_multivariate({top_cont: x.tolist()}, y.tolist())
    b = sf['coefficients'].get(top_cont, 0)
    a = sf.get('intercept', 0)
    current_pred = a + b * x_mean
    raised_pred = a + b * x_mean * 1.15
    delta = raised_pred - current_pred
    elasticity = (raised_pred/current_pred - 1) / 0.15 if current_pred != 0 else 0
    print(f"  Driver: {top_cont} (mean={x_mean:.2f})")
    print(f"  Predicted at current: {current_pred:.2f}")
    print(f"  Predicted at +15%:    {raised_pred:.2f}")
    print(f"  Change: {delta:+.2f} ({(raised_pred/current_pred - 1)*100:+.2f}%)")
    sens = 'HIGH (elastic)' if abs(elasticity) > 1 else ('UNIT elastic' if abs(elasticity) > 0.9 else 'LOW (inelastic)')
    print(f"  Elasticity: {elasticity:.2f} -- {sens}")

    # ---- Q4: How fast do sales change over time? ----
    print('\n' + '='*60)
    print('Q4: SALES TREND OVER TIME (FORECAST)')
    print('='*60)
    dates = cleaned.get('date', [])
    daily = defaultdict(list)
    for d, s in zip(dates, target_raw):
        daily[d].append(float(s))
    daily_sorted = sorted((d, np.mean(vals)) for d, vals in daily.items())
    y_ts = np.array([v for _, v in daily_sorted], dtype=float)
    x_ts = np.arange(len(y_ts), dtype=float)

    from src.fitting import fit_canonical_families
    try:
        fits = fit_canonical_families(x_ts.tolist(), y_ts.tolist())
        best = fits[0] if fits else None
        if best:
            r2 = best.stats.r2_adj
            print(f"  Best fit: {best.family} (adj-R²={r2:.4f})")
            print(f"  Params: {best.parameters}")
            if 'rate' in best.parameters:
                r = best.parameters['rate']
                direction = 'DECLINING' if r < 0 else 'GROWING'
                print(f"  Rate: {r:.6f} — {direction}")
                if r < 0:
                    hl = np.log(2) / abs(r)
                    print(f"  Half-life: {hl:.1f} days")
            elif 'b' in best.parameters:
                b = best.parameters['b']
                print(f"  Linear coef b: {b:.6f} — {'DECLINING' if b < 0 else 'GROWING'} at {abs(b):.4f}/day")
    except Exception as e:
        print(f"  Curve fit failed: {e}")

    # Forecast module
    try:
        from src.forecast import forecast
        fc = forecast(y_ts.tolist(), horizon=15)
        fc_vals = fc.get('forecast', [])
        if fc_vals:
            print(f"  Forecast next 15 days: avg {np.mean(fc_vals):.2f}, range [{np.min(fc_vals):.2f}, {np.max(fc_vals):.2f}]")
        if fc.get('trend'):
            print(f"  Trend: {fc['trend']}")
        if fc.get('seasonality_detected'):
            print(f"  Seasonality detected: period={fc.get('seasonality_period', '?')}")
    except Exception as e:
        print(f"  Forecast module: {e}")

    # ---- Q5: Which variable contributes most to sales? ----
    print('\n' + '='*60)
    print('Q5: WHICH VARIABLE CONTRIBUTES MOST TO SALES CHANGE?')
    print('='*60)
    if imp:
        top = sorted(imp.items(), key=lambda x: abs(x[1]), reverse=True)
        for i, (var, val) in enumerate(top[:3]):
            pct = abs(val) / sum(abs(v) for _, v in top) * 100 if top else 0
            print(f"  #{i+1}: {var}  contribution={val:.4f} ({pct:.0f}% of explained variance)")
    print(f"  Model R²: {fit.get('r2', 0):.4f}")

    # ---- Q6: What confidence should we have? ----
    print('\n' + '='*60)
    print('Q6: WHAT CONFIDENCE SHOULD WE HAVE?')
    print('='*60)
    r2 = fit.get('r2', 0)
    adj_r2 = fit.get('adj_r2', 0)
    aic = fit.get('aic', float('inf'))
    print(f"  R²:            {r2:.4f}")
    print(f"  Adjusted R²:   {adj_r2:.4f}")
    print(f"  AIC:           {aic:.2f}")
    print(f"  Sample:        {n_rows} rows × {len(encoded)} predictors")
    print(f"  CI method:     Jacobian-based J^T.J inverse x residual variance")
    if r2 > 0.5:
        print(f"  VERDICT: HIGH confidence ({r2*100:.0f}% variance explained)")
    elif r2 > 0.3:
        print(f"  VERDICT: MODERATE — useful directional insight")
    else:
        print(f"  VERDICT: LOW R² — rankings are reliable, predictions need domain knowledge")


if __name__ == '__main__':
    main()
