class TestMultiSolveAPI:
    def test_multiv_solve_linear(self, client):
        resp = client.post("/v2/solve", json={
            "query": "what drives revenue",
            "variables": {
                "customers": [10, 20, 30, 40, 50],
                "price": [100, 105, 95, 110, 90],
                "revenue": [1000, 2000, 3100, 3900, 5100],
            },
            "target": "revenue",
        })
        assert resp.status_code == 200
        data = resp.json()
        assert data["adj_r2"] > 0.9
        assert "customers" in data["coefficients"]
        assert data["n_obs"] == 5

    def test_multiv_solve_missing_target(self, client):
        resp = client.post("/v2/solve", json={
            "query": "test",
            "variables": {"a": [1, 2, 3], "b": [4, 5, 6]},
            "target": "c",
        })
        assert resp.status_code == 400

    def test_multiv_solve_with_evaluate(self, client):
        resp = client.post("/v2/solve", json={
            "query": "what if",
            "variables": {
                "x1": [1, 2, 3, 4, 5],
                "x2": [5, 4, 3, 2, 1],
                "y": [10 + 2*x1 + 3*x2 for x1, x2 in zip([1, 2, 3, 4, 5], [5, 4, 3, 2, 1])],
            },
            "target": "y",
            "evaluate_at": {"x1": 3.0, "x2": 3.0},
        })
        assert resp.status_code == 200
        data = resp.json()
        assert data["answer"] is not None
        assert abs(data["answer"] - 25.0) < 1.0  # 10 + 2*3 + 3*3 = 25

    def test_multiv_zero_variance_rejected(self, client):
        resp = client.post("/v2/solve", json={
            "query": "test",
            "variables": {
                "x": [5, 5, 5, 5, 5],
                "y": [1, 2, 3, 4, 5],
            },
            "target": "y",
        })
        assert resp.status_code == 422


