# ── Ledger Query Module ───────────────────────────────────────────────────────


class TestLedgerQueryModule:
    def test_list_variables_empty_for_fresh_db(self, db_path):
        variables = list_variables_in_ledger(db_path)
        assert isinstance(variables, list)
        assert len(variables) == 0

    def test_query_observations_empty(self, db_path):
        obs = query_observations(db_path, "mrr")
        assert isinstance(obs, list)
        assert len(obs) == 0

    def test_query_time_series_empty(self, db_path):
        vals, timestamps = query_time_series(db_path, "mrr")
        assert vals == []
        assert timestamps == []

    def test_get_latest_value_none(self, db_path):
        result = get_latest_value(db_path, "mrr")
        assert result is None
