from __future__ import annotations

from typing import Dict, List, Optional, Tuple

import numpy as np


def detect_categorical(
    values: List,
    max_unique_ratio: float = 0.05,
    max_unique_absolute: int = 20,
) -> bool:
    """Heuristic: a variable is categorical if it has few unique values relative to its size.

    Works on strings, floats that look like categories, or lists with few distinct values.
    """
    if not values:
        return False
    n = len(values)
    # Drop None/NaN
    cleaned = [v for v in values if v is not None]
    if not cleaned:
        return False

    # If all values are strings, check if they're actually numeric
    all_str = all(isinstance(v, str) for v in cleaned)
    if all_str:
        # Try parsing as float — if all succeed, they're numeric disguised as strings
        try:
            numeric_test = [float(v) for v in cleaned]
            unique = set(numeric_test)
            n_unique = len(unique)
            if n_unique <= 2:
                return True  # Binary numeric (could be 0/1 flag)
            if n_unique > 10:
                return False  # Continuous numeric — NOT categorical
            if n > 0 and n_unique / n <= max_unique_ratio:
                return True
            return False
        except (ValueError, TypeError):
            pass  # Genuinely string — fall through to categorical check below

        # Genuinely string values
        unique = set(cleaned)
        n_unique = len(unique)
        return n_unique <= max(max_unique_absolute, n * max_unique_ratio)

    # If all values are numeric (float/int), non-categorical unless binary or very low cardinality
    try:
        numeric_vals = [float(v) for v in cleaned]
        unique = set(numeric_vals)
        n_unique = len(unique)
        if n_unique <= 2:
            return True  # Binary numeric could be categorical (e.g., 0/1 flags)
        # More than 10 unique numeric values → continuous, NOT categorical
        if n_unique > 10:
            return False
        # 3-10 unique values with low cardinality ratio → could be ordinal
        if n > 0 and n_unique / n <= max_unique_ratio:
            return True
        return False
    except (ValueError, TypeError):
        # Mixed types — treat as categorical
        unique = set(str(v) for v in cleaned)
        n_unique = len(unique)
        return n_unique <= max(max_unique_absolute, n * max_unique_ratio)


def detect_all_categorical(
    columns: Dict[str, List],
    max_unique_ratio: float = 0.05,
    max_unique_absolute: int = 20,
) -> Dict[str, bool]:
    """Return {column_name: is_categorical} for all columns."""
    return {name: detect_categorical(vals, max_unique_ratio, max_unique_absolute)
            for name, vals in columns.items()}


def one_hot_encode(
    values: List,
    drop_first: bool = True,
) -> Tuple[Dict[str, List[float]], List[str]]:
    """One-hot encode a categorical variable.

    Returns ({encoded_column_name: [0/1 values]}, category_labels).
    drop_first=True avoids the dummy variable trap for regression.
    """
    if not values:
        return {}, []

    unique = sorted(set(str(v) for v in values if v is not None))
    if drop_first and len(unique) > 1:
        categories = unique[1:]  # Drop first as reference
    else:
        categories = unique

    encoded: Dict[str, List[float]] = {}
    for cat in categories:
        encoded[cat] = [1.0 if str(v) == cat else 0.0 for v in values]

    return encoded, categories


def label_encode(values: List) -> Tuple[List[float], Dict[str, int]]:
    """Label-encode (ordinal) a categorical variable. Returns (encoded_values, mapping)."""
    unique = sorted(set(str(v) for v in values if v is not None))
    mapping = {cat: i for i, cat in enumerate(unique)}
    encoded = [float(mapping.get(str(v), 0)) for v in values]
    return encoded, mapping


def clean_column(
    values: List,
    fill_empty: bool = True,
    empty_fill_value: str = "missing",
) -> List:
    """Clean a column from CSV data: strip whitespace, handle None/NaN/empty.

    Returns cleaned list with consistent string representation for categoricals.
    """
    cleaned = []
    for v in values:
        if v is None:
            if fill_empty:
                cleaned.append(empty_fill_value)
            else:
                cleaned.append(None)
            continue
        if isinstance(v, str):
            stripped = v.strip()
            if not stripped:
                if fill_empty:
                    cleaned.append(empty_fill_value)
                else:
                    cleaned.append(None)
            else:
                cleaned.append(stripped)
        elif isinstance(v, float) and (v != v):  # NaN check
            if fill_empty:
                cleaned.append(empty_fill_value)
            else:
                cleaned.append(None)
        else:
            cleaned.append(v)
    return cleaned


def is_id_column(values: List) -> bool:
    """Detect if a column is likely an ID/key column (very high cardinality strings)."""
    if not values:
        return False
    n = len(values)
    if n < 20:
        return False  # Too small to reliably detect — not an ID column
    unique = set(str(v) for v in values if v is not None)
    n_unique = len(unique)
    # If >90% of values are unique and we have enough rows, it's an ID column
    return n_unique > n * 0.9


def auto_encode(
    columns: Dict[str, List],
    categorical_flags: Optional[Dict[str, bool]] = None,
) -> Dict[str, List[float]]:
    """Auto-detect and encode categorical columns. Returns all-numeric column dict.

    - ID columns: skipped
    - Numeric columns: passed through unchanged
    - Binary categorical: label-encoded (0/1)
    - Multi-category: one-hot encoded (drop_first)
    - String non-categorical (missed detection): label-encoded for safety
    """
    if categorical_flags is None:
        categorical_flags = detect_all_categorical(columns)

    result: Dict[str, List[float]] = {}
    for name, vals in columns.items():
        # Skip ID columns
        if is_id_column(vals):
            continue

        is_cat = categorical_flags.get(name, False)

        if not is_cat:
            # Try numeric conversion; if it fails (string column not detected as cat),
            # force label-encode
            try:
                result[name] = [float(v) if v is not None else 0.0 for v in vals]
                continue
            except (ValueError, TypeError):
                # String column missed by detection — label-encode
                encoded_vals, _ = label_encode(vals)
                result[name] = encoded_vals
                continue

        unique_count = len(set(str(v) for v in vals if v is not None))
        if unique_count <= 2:
            encoded_vals, _ = label_encode(vals)
            result[name] = encoded_vals
        else:
            encoded_cols, _ = one_hot_encode(vals, drop_first=True)
            for enc_name, enc_vals in encoded_cols.items():
                result[f"{name}_{enc_name}"] = enc_vals

    return result
