from __future__ import annotations

import sqlite3
from datetime import datetime, timezone
from typing import Any, Dict, List, Optional, Tuple


def query_observations(
    db_path: str,
    variable: str,
    start_time: Optional[str] = None,
    end_time: Optional[str] = None,
    entity_id: Optional[str] = None,
    limit: int = 10_000,
) -> List[Dict[str, Any]]:
    """Retrieve observations for a variable from the observation_ledger.

    Returns rows as dicts with keys: value, unit, timestamp, entity_id, quality_score.
    """
    parts = ["SELECT value, unit, timestamp, entity_id, quality_score FROM observation_ledger WHERE variable = ?"]
    params: List[Any] = [variable]

    if start_time:
        parts.append("AND timestamp >= ?")
        params.append(start_time)
    if end_time:
        parts.append("AND timestamp <= ?")
        params.append(end_time)
    if entity_id:
        parts.append("AND entity_id = ?")
        params.append(entity_id)

    parts.append("ORDER BY timestamp ASC LIMIT ?")
    params.append(limit)

    with sqlite3.connect(db_path) as conn:
        conn.row_factory = sqlite3.Row
        rows = conn.execute(" ".join(parts), params).fetchall()

    return [dict(r) for r in rows]


def query_time_series(
    db_path: str,
    variable: str,
    start_time: Optional[str] = None,
    end_time: Optional[str] = None,
) -> Tuple[List[float], List[str]]:
    """Retrieve a time series as (values, timestamps) ordered by time."""
    obs = query_observations(db_path, variable, start_time=start_time, end_time=end_time)
    values = [float(o["value"]) for o in obs if o["value"] is not None]
    timestamps = [o["timestamp"] for o in obs if o["value"] is not None]
    return values, timestamps


def list_variables_in_ledger(db_path: str) -> List[Dict[str, Any]]:
    """List all unique variables in the observation_ledger with observation counts."""
    with sqlite3.connect(db_path) as conn:
        conn.row_factory = sqlite3.Row
        rows = conn.execute(
            "SELECT variable, COUNT(*) as n_obs, MIN(timestamp) as first_seen, MAX(timestamp) as last_seen "
            "FROM observation_ledger GROUP BY variable ORDER BY n_obs DESC"
        ).fetchall()
    return [dict(r) for r in rows]


def get_latest_value(db_path: str, variable: str) -> Optional[Dict[str, Any]]:
    """Get the most recent observation for a variable."""
    with sqlite3.connect(db_path) as conn:
        conn.row_factory = sqlite3.Row
        row = conn.execute(
            "SELECT value, unit, timestamp, entity_id FROM observation_ledger "
            "WHERE variable = ? AND value IS NOT NULL ORDER BY timestamp DESC LIMIT 1",
            (variable,),
        ).fetchone()
    return dict(row) if row else None


def query_pair(
    db_path: str,
    x_variable: str,
    y_variable: str,
    start_time: Optional[str] = None,
    end_time: Optional[str] = None,
    limit: int = 10_000,
) -> Tuple[List[float], List[float], List[str]]:
    """Retrieve aligned (x_values, y_values, timestamps) for two variables.

    Matches observations by closest timestamp within a 1-hour window.
    """
    x_vals, x_ts = query_time_series(db_path, x_variable, start_time, end_time)
    y_obs = query_observations(db_path, y_variable, start_time, end_time, limit=limit)
    if not x_vals or not y_obs:
        return [], [], []

    # Build a dict of y by timestamp for fast lookup
    y_by_ts: Dict[str, float] = {}
    for obs in y_obs:
        ts = obs["timestamp"]
        val = obs["value"]
        if ts is not None and val is not None:
            y_by_ts[ts] = float(val)

    x_out: List[float] = []
    y_out: List[float] = []
    ts_out: List[str] = []

    # Simple alignment: match by exact timestamp, then by closest
    # First pass: exact matches
    y_ts_list = sorted(y_by_ts.keys())
    for i, ts in enumerate(x_ts):
        if ts in y_by_ts:
            x_out.append(x_vals[i])
            y_out.append(y_by_ts[ts])
            ts_out.append(ts)

    # Second pass: closest timestamp within 1 hour
    if not x_out:
        for i, ts in enumerate(x_ts):
            try:
                from datetime import timedelta
                ts_dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
                best_val = None
                best_delta = timedelta(hours=1)
                for y_ts in y_ts_list:
                    try:
                        y_dt = datetime.fromisoformat(y_ts.replace("Z", "+00:00"))
                        delta = abs(ts_dt - y_dt)
                        if delta < best_delta:
                            best_delta = delta
                            best_val = y_by_ts[y_ts]
                    except (ValueError, TypeError):
                        continue
                if best_val is not None:
                    x_out.append(x_vals[i])
                    y_out.append(best_val)
                    ts_out.append(ts)
            except (ValueError, TypeError):
                continue

    return x_out, y_out, ts_out
