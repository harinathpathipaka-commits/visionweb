apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: equation-layer-ingress
  labels:
    app: equation-layer
  annotations:
    cert-manager.io/cluster-issuer: letsencrypt-prod
    nginx.ingress.kubernetes.io/limit-rps: "50"
    nginx.ingress.kubernetes.io/proxy-body-size: "10m"
spec:
  ingressClassName: nginx
  tls:
    - hosts:
        - api.equation-layer.example.com
      secretName: equation-layer-tls
  rules:
    - host: api.equation-layer.example.com
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: equation-layer-api
                port:
                  number: 8000
