use std::collections::HashMap;

use crate::ingestion::ObservationDraft;

/// Frequency labels for temporal alignment.
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub enum Frequency {
    Daily,
    Weekly,
    Monthly,
    Quarterly,
    Annual,
    Irregular,
}

impl Frequency {
    pub fn as_str(&self) -> &'static str {
        match self {
            Frequency::Daily => "daily",
            Frequency::Weekly => "weekly",
            Frequency::Monthly => "monthly",
            Frequency::Quarterly => "quarterly",
            Frequency::Annual => "annual",
            Frequency::Irregular => "irregular",
        }
    }

    pub fn from_str(s: &str) -> Self {
        match s.to_lowercase().as_str() {
            "daily" => Frequency::Daily,
            "weekly" => Frequency::Weekly,
            "monthly" => Frequency::Monthly,
            "quarterly" => Frequency::Quarterly,
            "annual" => Frequency::Annual,
            _ => Frequency::Irregular,
        }
    }

    pub fn bucket_key(&self, ts: &str) -> String {
        match self {
            Frequency::Daily => ts.chars().take(10).collect(),
            Frequency::Weekly => {
                // Simple week bucket from date string
                if ts.len() >= 10 {
                    let year: String = ts.chars().take(4).collect();
                    let month: String = ts.chars().skip(5).take(2).collect();
                    let day: String = ts.chars().skip(8).take(2).collect();
                    let d: u32 = day.parse().unwrap_or(1);
                    let w = (d - 1) / 7 + 1;
                    format!("{}-W{:02}", year, w)
                } else {
                    ts.to_string()
                }
            }
            Frequency::Monthly => ts.chars().take(7).collect(),
            Frequency::Quarterly => {
                if ts.len() >= 7 {
                    let year: String = ts.chars().take(4).collect();
                    let month: u32 = ts.chars().skip(5).take(2).collect::<String>().parse().unwrap_or(1);
                    let q = (month - 1) / 3 + 1;
                    format!("{}-Q{}", year, q)
                } else {
                    ts.to_string()
                }
            }
            Frequency::Annual => ts.chars().take(4).collect(),
            Frequency::Irregular => ts.to_string(),
        }
    }
}

/// Detect the dominant frequency from a list of timestamps.
pub fn detect_frequency(timestamps: &[String]) -> Frequency {
    if timestamps.len() < 5 {
        return Frequency::Irregular;
    }

    let mut gaps: Vec<f64> = Vec::new();
    for i in 1..timestamps.len() {
        if let (Some(a), Some(b)) = (parse_days(&timestamps[i - 1]), parse_days(&timestamps[i])) {
            let gap = (b - a).abs();
            if gap > 0.0 {
                gaps.push(gap);
            }
        }
    }

    if gaps.is_empty() {
        return Frequency::Irregular;
    }

    gaps.sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal));
    let median = gaps[gaps.len() / 2];

    if median <= 2.0 {
        Frequency::Daily
    } else if median <= 10.0 {
        Frequency::Weekly
    } else if median <= 45.0 {
        Frequency::Monthly
    } else if median <= 120.0 {
        Frequency::Quarterly
    } else if median <= 400.0 {
        Frequency::Annual
    } else {
        Frequency::Irregular
    }
}

/// Align observations to a target frequency using the specified aggregation method.
pub fn align_to_frequency(
    observations: &[ObservationDraft],
    target: Frequency,
    method: &str,
    detected: Frequency,
) -> Vec<ObservationDraft> {
    if detected == target {
        return observations.to_vec();
    }

    let mut buckets: HashMap<String, Vec<f64>> = HashMap::new();
    let mut meta: HashMap<String, (String, String)> = HashMap::new(); // (variable, unit)

    for obs in observations {
        let key = target.bucket_key(&obs.timestamp);
        buckets.entry(key.clone()).or_default().push(obs.value);
        meta.entry(key).or_insert((obs.variable.clone(), obs.unit.clone()));
    }

    let mut aligned: Vec<ObservationDraft> = Vec::new();
    for (key, values) in &buckets {
        if values.is_empty() {
            continue;
        }
        let agg = aggregate(values, method);
        let (variable, unit) = meta.get(key).cloned().unwrap_or_default();
        aligned.push(ObservationDraft {
            variable,
            value: agg,
            unit,
            timestamp: key.clone(),
            entity_id: String::new(),
            row_index: 0,
        });
    }
    aligned.sort_by(|a, b| a.timestamp.cmp(&b.timestamp));
    aligned
}

fn aggregate(values: &[f64], method: &str) -> f64 {
    match method {
        "sum" => values.iter().sum(),
        "last" => *values.last().unwrap_or(&0.0),
        "first" => *values.first().unwrap_or(&0.0),
        "median" => {
            let mut sorted: Vec<f64> = values.to_vec();
            sorted.sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal));
            if sorted.is_empty() {
                0.0
            } else {
                sorted[sorted.len() / 2]
            }
        }
        _ => values.iter().sum::<f64>() / values.len() as f64, // mean
    }
}

fn parse_days(ts: &str) -> Option<f64> {
    if ts.len() < 10 {
        return None;
    }
    let year: i32 = ts[..4].parse().ok()?;
    let month: u32 = ts[5..7].parse().ok()?;
    let day: u32 = ts[8..10].parse().ok()?;
    // Simple day-of-year calculation (not accounting for leap years precisely)
    let month_days = [0, 31, 59, 90, 120, 151, 181, 212, 243, 273, 304, 334];
    let m_idx = (month as usize).saturating_sub(1).min(11);
    Some((year as f64 * 365.25) + month_days[m_idx] as f64 + day as f64)
}
