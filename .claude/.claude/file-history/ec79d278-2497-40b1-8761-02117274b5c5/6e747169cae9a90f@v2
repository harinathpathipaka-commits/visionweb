/// Compute residuals: y_i - f(x_i; params) for each point.
pub fn compute_residuals<F>(x: &[f64], y: &[f64], model_fn: F) -> Vec<f64>
where
    F: Fn(f64) -> f64,
{
    x.iter()
        .zip(y.iter())
        .map(|(&xi, &yi)| yi - model_fn(xi))
        .collect()
}

/// Mean Absolute Percentage Error.
pub fn compute_mape(x: &[f64], y: &[f64], model_fn: impl Fn(f64) -> f64) -> f64 {
    if x.is_empty() {
        return 0.0;
    }
    let sum: f64 = x
        .iter()
        .zip(y.iter())
        .map(|(&xi, &yi)| {
            let pred = model_fn(xi);
            if yi.abs() < 1e-10 {
                0.0
            } else {
                ((yi - pred) / yi).abs()
            }
        })
        .sum();
    sum / x.len() as f64
}

/// R-squared (coefficient of determination).
pub fn compute_r2(x: &[f64], y: &[f64], model_fn: impl Fn(f64) -> f64) -> f64 {
    if x.is_empty() || y.is_empty() {
        return 0.0;
    }
    let mean_y = y.iter().sum::<f64>() / y.len() as f64;
    let ss_res: f64 = x
        .iter()
        .zip(y.iter())
        .map(|(&xi, &yi)| (yi - model_fn(xi)).powi(2))
        .sum();
    let ss_tot: f64 = y.iter().map(|&yi| (yi - mean_y).powi(2)).sum();
    if ss_tot < 1e-15 {
        0.0
    } else {
        1.0 - (ss_res / ss_tot)
    }
}

/// Adjusted R-squared: 1 - (1-R²) * (n-1)/(n-p-1) where p = number of params.
pub fn compute_r2_adj(r2: f64, n: usize, p: usize) -> f64 {
    if n <= p + 1 {
        return r2;
    }
    let denom = (n - p - 1) as f64;
    if denom < 1.0 {
        return r2;
    }
    1.0 - ((1.0 - r2) * (n - 1) as f64 / denom)
}

/// Akaike Information Criterion: n * ln(RSS/n) + 2k.
pub fn compute_aic(residuals: &[f64], n_params: usize) -> f64 {
    let n = residuals.len();
    if n == 0 {
        return f64::INFINITY;
    }
    let rss: f64 = residuals.iter().map(|r| r.powi(2)).sum();
    let sigma2 = rss / n as f64;
    if sigma2 < 1e-15 {
        return f64::NEG_INFINITY;
    }
    n as f64 * sigma2.ln() + 2.0 * (n_params + 1) as f64
}

/// Bootstrap sampling: draw `n_samples` bootstrap samples with replacement.
pub fn bootstrap_sample<T: Clone>(data: &[T], n_samples: usize) -> Vec<Vec<T>> {
    use rand::Rng;
    let mut rng = rand::thread_rng();
    let n = data.len();
    (0..n_samples)
        .map(|_| {
            (0..n)
                .map(|_| data[rng.gen_range(0..n)].clone())
                .collect()
        })
        .collect()
}

/// Bootstrap confidence interval for a statistic via percentile method.
pub fn bootstrap_ci(
    data: &[f64],
    statistic: impl Fn(&[f64]) -> f64,
    n_samples: usize,
    alpha: f64,
) -> (f64, f64) {
    let bootstrap_stats: Vec<f64> = if data.len() < 20 {
        // Jackknife for small datasets
        (0..data.len())
            .map(|i| {
                let subset: Vec<f64> = data
                    .iter()
                    .enumerate()
                    .filter(|&(j, _)| j != i)
                    .map(|(_, &v)| v)
                    .collect();
                statistic(&subset)
            })
            .collect()
    } else {
        let samples = bootstrap_sample(data, n_samples);
        samples.iter().map(|s| statistic(s)).collect()
    };

    let mut sorted = bootstrap_stats;
    sorted.sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal));
    let lower_idx = (alpha / 2.0 * sorted.len() as f64).floor() as usize;
    let upper_idx = ((1.0 - alpha / 2.0) * sorted.len() as f64).ceil() as usize;
    (
        sorted[lower_idx.min(sorted.len() - 1)],
        sorted[upper_idx.min(sorted.len() - 1)],
    )
}

/// Shapiro-Wilk test for normality (simplified approximation via sorted residuals).
/// Returns true if residuals appear normally distributed.
pub fn shapiro_wilk(residuals: &[f64]) -> bool {
    let n = residuals.len();
    if n < 3 {
        return true;
    }
    let mut sorted: Vec<f64> = residuals.to_vec();
    sorted.sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal));

    let mean = sorted.iter().sum::<f64>() / n as f64;
    let variance = sorted.iter().map(|x| (x - mean).powi(2)).sum::<f64>() / n as f64;
    let std = variance.sqrt();
    if std < 1e-15 {
        return true;
    }

    // Simplified SW: use z-score skewness/kurtosis as a quick normality proxy.
    let skewness: f64 =
        sorted.iter().map(|x| ((x - mean) / std).powi(3)).sum::<f64>() / n as f64;
    let kurtosis: f64 =
        sorted.iter().map(|x| ((x - mean) / std).powi(4)).sum::<f64>() / n as f64;

    // Accept if skewness is within [-1, 1] and kurtosis within [1.5, 4.5].
    skewness.abs() <= 1.0 && (1.5..=4.5).contains(&kurtosis)
}

/// Durbin-Watson statistic: tests for autocorrelation in residuals.
/// Values near 2 indicate no autocorrelation. <1 or >3 suggests autocorrelation.
pub fn durbin_watson(residuals: &[f64]) -> f64 {
    if residuals.len() < 2 {
        return 2.0;
    }
    let num: f64 = residuals
        .windows(2)
        .map(|w| (w[1] - w[0]).powi(2))
        .sum();
    let denom: f64 = residuals.iter().map(|r| r.powi(2)).sum();
    if denom < 1e-15 {
        return 2.0;
    }
    num / denom
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_r2_perfect() {
        let x: Vec<f64> = (0..10).map(|i| i as f64).collect();
        let y: Vec<f64> = x.iter().map(|&xi| 2.0 * xi + 1.0).collect();
        let r2 = compute_r2(&x, &y, |xi| 2.0 * xi + 1.0);
        assert!((r2 - 1.0).abs() < 1e-10);
    }

    #[test]
    fn test_mape_zero() {
        let x = vec![1.0, 2.0, 3.0];
        let y = vec![3.0, 5.0, 7.0];
        let mape = compute_mape(&x, &y, |xi| 2.0 * xi + 1.0);
        assert!(mape < 1e-10);
    }

    #[test]
    fn test_durbin_watson_approx_two() {
        let residuals = vec![0.1, -0.2, 0.05, 0.15, -0.1, 0.0];
        let dw = durbin_watson(&residuals);
        assert!((0.5..3.5).contains(&dw));
    }
}
