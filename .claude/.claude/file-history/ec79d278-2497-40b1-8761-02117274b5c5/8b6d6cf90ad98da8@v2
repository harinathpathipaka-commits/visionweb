[package]
name = "fit_kernel"
version = "0.1.0"
edition = "2021"

[lib]
name = "fit_kernel"
crate-type = ["cdylib", "rlib"]

[dependencies]
pyo3 = { version = "0.21", features = ["extension-module"], optional = true }
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
rand = "0.8"

[features]
python = ["pyo3"]
